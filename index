<script>
/* ====================== CORE ====================== */
const $=id=>document.getElementById(id);
function escapeHtml(s){return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
const num=id=>{const e=$(id);if(!e)return null;const v=parseFloat((e.value+'').replace(',','.'));return isNaN(v)?null:v;};
const fmt=(v,d=1)=>v==null||isNaN(v)?'—':v.toLocaleString('pt-BR',{minimumFractionDigits:d,maximumFractionDigits:d});

/* ----- formulas (validadas contra Excel) ----- */
const F={
  sc:(p,a)=>0.007184*Math.pow(p,0.425)*Math.pow(a,0.725),     // DuBois (adulto)
  scHaycock:(p,a)=>0.024265*Math.pow(p,0.5378)*Math.pow(a,0.3964), // Haycock (pediátrico)
  teich:dmm=>{const d=dmm/10;return (7/(2.4+d))*Math.pow(d,3);},
  massa:(d,s,p)=>{d/=10;s/=10;p/=10;return 0.8*(1.04*(Math.pow(d+s+p,3)-Math.pow(d,3)))+0.6;},
  erp:(pp,d)=>(2*pp)/d,
  eemedia:(E,es,el)=>((E/es)+(E/el))/2,
  psap:(v,pad)=>4*v*v+pad
};

/* ============================================================
   Pettersen 2008 — Z-scores pediátricos (Tabela 2 do paper)
   Modelo: ln(measurement_cm) = β₀ + β₁·BSA + β₂·BSA² + β₃·BSA³
   Z = (ln(observed_cm) − Mean_y) / √MSE
   Limite de validade: BSA < 2.0 m²
   Fonte: J Am Soc Echocardiogr 2008;21(8):922-934
   Estruturas medidas em centímetros (cm) — conversão automática a partir de mm.
   ============================================================ */
const PETTERSEN_Z = {
  RVDd:           {b0:-0.317, b1: 1.850, b2:-1.274, b3: 0.335, mse:0.058, r2:0.604, lbl:'VD — diâmetro diastólico'},
  IVSd:           {b0:-1.242, b1: 1.272, b2:-0.762, b3: 0.208, mse:0.046, r2:0.606, lbl:'Septo interventricular (diástole)'},
  IVSs:           {b0:-1.048, b1: 1.751, b2:-1.177, b3: 0.318, mse:0.034, r2:0.695, lbl:'Septo interventricular (sístole)'},
  LVIDd:          {b0: 0.105, b1: 2.859, b2:-2.119, b3: 0.552, mse:0.010, r2:0.922, lbl:'VE — diâmetro diastólico'},
  LVIDs:          {b0:-0.371, b1: 2.833, b2:-2.081, b3: 0.538, mse:0.016, r2:0.875, lbl:'VE — diâmetro sistólico'},
  LVPWd:          {b0:-1.586, b1: 1.849, b2:-1.188, b3: 0.313, mse:0.037, r2:0.739, lbl:'Parede posterior (diástole)'},
  LVPWs:          {b0:-0.947, b1: 1.907, b2:-1.259, b3: 0.330, mse:0.023, r2:0.794, lbl:'Parede posterior (sístole)'},
  AoAnn:          {b0:-0.874, b1: 2.708, b2:-1.841, b3: 0.452, mse:0.010, r2:0.934, lbl:'Anel aórtico'},
  AoSinus:        {b0:-0.500, b1: 2.537, b2:-1.707, b3: 0.420, mse:0.012, r2:0.916, lbl:'Seios de Valsalva'},
  AoStj:          {b0:-0.759, b1: 2.643, b2:-1.797, b3: 0.442, mse:0.018, r2:0.878, lbl:'Junção sinotubular'},
  AoArchT:        {b0:-0.790, b1: 3.020, b2:-2.484, b3: 0.712, mse:0.023, r2:0.865, lbl:'Arco aórtico transverso'},
  AoIsthmus:      {b0:-1.072, b1: 2.539, b2:-1.627, b3: 0.368, mse:0.027, r2:0.825, lbl:'Istmo aórtico'},
  AoArchD:        {b0:-0.976, b1: 2.469, b2:-1.746, b3: 0.445, mse:0.026, r2:0.792, lbl:'Arco aórtico distal'},
  AoDiaph:        {b0:-0.922, b1: 2.100, b2:-1.411, b3: 0.371, mse:0.018, r2:0.842, lbl:'Aorta ao nível do diafragma'},
  PvAnn:          {b0:-0.761, b1: 2.774, b2:-1.808, b3: 0.436, mse:0.023, r2:0.873, lbl:'Anel pulmonar'},
  MPA:            {b0:-0.707, b1: 2.746, b2:-1.807, b3: 0.424, mse:0.024, r2:0.857, lbl:'Tronco pulmonar'},
  RPA:            {b0:-1.360, b1: 3.394, b2:-2.508, b3: 0.660, mse:0.027, r2:0.873, lbl:'APD — artéria pulmonar direita'},
  LPA:            {b0:-1.348, b1: 2.884, b2:-1.954, b3: 0.466, mse:0.028, r2:0.842, lbl:'APE — artéria pulmonar esquerda'},
  MvAnn:          {b0:-0.271, b1: 2.446, b2:-1.700, b3: 0.425, mse:0.022, r2:0.826, lbl:'Anel mitral'},
  TvAnn:          {b0:-0.164, b1: 2.341, b2:-1.596, b3: 0.387, mse:0.036, r2:0.726, lbl:'Anel tricúspide'},
  LA:             {b0:-0.208, b1: 2.164, b2:-1.597, b3: 0.429, mse:0.020, r2:0.801, lbl:'Átrio esquerdo (AP)'},
