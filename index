<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ENCOR · Ecocardiograma Transtorácico</title>

<!-- ===== PWA (app instalável + offline) ===== -->
<meta name="theme-color" content="#0e1116">
<meta name="description" content="Gerador de laudos de ecocardiograma — Clínica ENCOR / Dr. Genius Costa">
<link rel="manifest" href="./manifest.webmanifest">
<link rel="icon" type="image/png" sizes="32x32" href="./icons/favicon-32.png">
<link rel="apple-touch-icon" href="./icons/apple-touch-icon.png">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Echo ENCOR">
<meta name="mobile-web-app-capable" content="yes">

<!-- Bibliotecas de PDF: arquivos LOCAIS (offline). Fallback para CDN apenas se o HTML for
     aberto solto, sem a pasta ./vendor (ex.: duplo-clique fora do deploy). -->
<script src="./vendor/html2canvas.min.js"></script>
<script src="./vendor/jspdf.umd.min.js"></script>
<script>
  if(typeof html2canvas==='undefined'){document.write('<scr'+'ipt src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"><\/scr'+'ipt>');}
  if(typeof window.jspdf==='undefined' && typeof window.jsPDF==='undefined'){document.write('<scr'+'ipt src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"><\/scr'+'ipt>');}
</script>
<style>
  :root{
    --bg:#0e1116; --panel:#161d26; --panel2:#1d2630; --line:#2a3642;
    --ink:#e8edf2; --dim:#9aa9b8; --accent:#3fb6a8; --accent-d:#2a8478;
    --warn:#e8554e; --warn-bg:#2a1614; --calc:#7aa2c8; --hdr:#0b0f14;
    --chip:#222e3a; --chip-on:#2a8478; --chip-on-ink:#eafffb;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%}
  body{font-family:"Segoe UI",system-ui,sans-serif;background:var(--bg);color:var(--ink);font-size:13.5px;line-height:1.4;display:flex;flex-direction:column}
  /* top bar */
  .topbar{background:var(--hdr);border-bottom:1px solid var(--line);padding:8px 16px;display:flex;align-items:center;gap:14px;flex:0 0 auto}
  .modo-toggle{display:inline-flex;background:var(--panel2);border:1px solid var(--line);border-radius:6px;overflow:hidden}
  .modo-btn{background:transparent;border:none;color:var(--dim);padding:5px 12px;font-size:12.5px;font-weight:600;cursor:pointer;border-right:1px solid var(--line)}
  .modo-btn:last-child{border-right:none}
  .modo-btn:hover{background:rgba(255,255,255,.04);color:var(--ink)}
  .modo-btn.active{background:var(--accent-d);color:#fff}
  body.mode-ped .modo-btn.active{background:#7a3a8c}  /* roxo para distinguir modo pediátrico */
  body.mode-ped #blkDiast{display:none}
  body.mode-ped #fldSexo{display:none}
  /* blocos pediátricos: ocultos em adulto, visíveis em pediátrico */
  .ped-only{display:none}
  body.mode-ped .ped-only{display:block}
  /* coluna Z-score na grade pediátrica */
  .z-cell{font-size:8.5pt;font-weight:600;text-align:center;padding:2px 4px;border-radius:3px;display:inline-block;min-width:46px}
  .z-cell.z-normal{background:#0a4f1a;color:#a5e8b8}
  .z-cell.z-lev   {background:#a36a0a;color:#fff}
  .z-cell.z-mod   {background:#a04a0a;color:#fff}
  .z-cell.z-grav  {background:#8a1a1a;color:#fff}
  .topbar h1{font-size:14px;font-weight:600;letter-spacing:.3px}
  .topbar .tag{font-family:ui-monospace,monospace;font-size:11px;color:var(--accent);border:1px solid var(--accent-d);padding:2px 7px;border-radius:4px}
  .topbar .sp{margin-left:auto}
  .topbar button{background:var(--panel2);border:1px solid var(--line);color:var(--ink);padding:5px 11px;border-radius:6px;font-size:12px;cursor:pointer}
  .topbar button:hover{border-color:var(--accent)}
  /* layout */
  .main{flex:1 1 auto;display:grid;grid-template-columns:1fr 1fr;overflow:hidden}
  .editor{overflow-y:auto;border-right:1px solid var(--line);padding:0 0 60px}
  .preview-pane{overflow-y:auto;background:#0a0d12;padding:20px;display:flex;justify-content:center}
  .pages{display:flex;flex-direction:column;gap:16px;transform-origin:top center}
  /* tabs */
  .tabs{display:flex;position:sticky;top:0;background:var(--hdr);z-index:5;border-bottom:1px solid var(--line)}
  .tabs button{flex:1;background:none;border:none;border-bottom:2px solid transparent;color:var(--dim);padding:11px 6px;font-size:12.5px;cursor:pointer;font-weight:600;letter-spacing:.3px}
  .tabs button.active{color:var(--accent);border-bottom-color:var(--accent)}
  .tabpane{display:none;padding:16px}
  .tabpane.active{display:block}
  /* fields */
  .row2{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px}
  .fld{display:flex;flex-direction:column;gap:4px}
  .fld label{font-size:10.5px;color:var(--dim);text-transform:uppercase;letter-spacing:.5px}
  .fld input,.fld select{background:var(--panel2);border:1px solid var(--line);color:var(--ink);padding:7px 9px;border-radius:6px;font-size:13.5px}
  .fld.sm input{width:86px} .fld.md input{width:120px} .fld.lg input,.fld.lg select{min-width:230px}
  .sc-pill{margin-left:auto;text-align:right;align-self:flex-end}
  .sc-pill .b{font-size:20px;font-weight:700;color:var(--accent)} .sc-pill .l{font-size:10px;color:var(--dim)}
  /* measure block */
  .mblock{background:var(--panel);border:1px solid var(--line);border-radius:9px;margin-bottom:12px;overflow:hidden}
  .mblock h3{background:var(--panel2);font-size:11px;letter-spacing:.8px;text-transform:uppercase;padding:7px 13px;color:var(--accent);border-bottom:1px solid var(--line);font-weight:700}
  table.m{width:100%;border-collapse:collapse}
  table.m td{padding:5px 10px;border-bottom:1px solid var(--line)}
  table.m tr:last-child td{border-bottom:none}
  td.nm{color:var(--ink);width:48%} td.cn{color:var(--calc);font-style:italic;width:48%}
  td.ip{width:20%} td.un{color:var(--dim);width:9%;font-size:11.5px} td.rf{color:var(--dim);width:14%;font-size:11.5px;text-align:right}
  td.vl{font-weight:600;text-align:right;width:18%;font-variant-numeric:tabular-nums}
  .out td.vl{color:var(--calc)}
  input.mm{background:var(--panel2);border:1px solid var(--line);color:var(--ink);padding:4px 7px;border-radius:5px;width:78px;text-align:right;font-size:13px;font-variant-numeric:tabular-nums}
  input.mm:focus{outline:none;border-color:var(--accent)}
  tr.flag{background:var(--warn-bg)!important} tr.flag td.vl,tr.flag input.mm{color:var(--warn)!important} tr.flag td.rf{color:var(--warn)}
  .badge{display:inline-block;font-size:9px;padding:1px 4px;border-radius:3px;margin-left:5px;font-weight:700;vertical-align:middle}
  .badge.hi{background:var(--warn);color:#fff} .badge.lo{background:var(--calc);color:#0b0f14}
  .geom{padding:9px 13px;font-size:12.5px;border-top:1px solid var(--line);background:var(--panel2)}
  .geom b{color:var(--accent)}
  /* chips */
  .seg{margin-bottom:14px}
  .seg .seg-h{font-size:11px;text-transform:uppercase;letter-spacing:.6px;color:var(--accent);font-weight:700;margin-bottom:6px;padding-bottom:4px;border-bottom:1px solid var(--line)}
  .chips{display:flex;flex-wrap:wrap;gap:6px}
  .chip{background:var(--chip);border:1px solid var(--line);color:var(--ink);padding:5px 10px;border-radius:14px;font-size:12px;cursor:pointer;user-select:none;transition:.12s}
  .chip:hover{border-color:var(--accent)}
  .chip.on{background:var(--chip-on);border-color:var(--accent);color:var(--chip-on-ink);font-weight:600}
  .editline{margin-top:8px}
  .editline textarea{width:100%;background:var(--panel2);border:1px solid var(--line);color:var(--ink);border-radius:6px;padding:8px;font-size:13px;font-family:inherit;resize:vertical;min-height:54px}
  .hint{font-size:11px;color:var(--dim);margin-top:4px}
  .sig-tools{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap}
  .sig-tools button{background:var(--panel2);border:1px solid var(--line);color:var(--ink);padding:5px 10px;border-radius:6px;font-size:11.5px;cursor:pointer}
  /* ---------- A4 PREVIEW ---------- */
  .a4{position:relative;flex:0 0 auto;width:210mm;height:297mm;background:#fff;color:#1a1a1a;box-shadow:0 4px 24px rgba(0,0,0,.5);overflow:hidden}
  .a4 .bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0}
  .a4 .content{position:relative;z-index:1;padding:18mm 16mm 16mm}
  .doc-title{text-align:center;font-weight:700;font-size:10.5pt;margin:20mm 0 10px;letter-spacing:0;white-space:nowrap}
  .idtab{width:100%;border-collapse:collapse;font-size:10.5pt;margin-bottom:12px}
  .idtab td{border:1px solid #333;padding:3px 7px}
  .idtab .k{font-weight:700;width:60px;white-space:nowrap}
  .sec-label{font-weight:700;font-size:11pt;margin:12px 0 5px}
  .sec-label.center{text-align:center;letter-spacing:.5px}
  .meas-grid{font-size:8.2pt;border-collapse:collapse;width:100%;margin-bottom:6px}
  .meas-grid td{padding:0.8px 5px;border-bottom:1px solid #e8e8e8}
  .meas-grid .g-h{font-weight:700;background:#eef3f5;color:#15514a}
  .meas-grid .lbl{width:55%} .meas-grid .v{text-align:right;font-weight:600;width:20%} .meas-grid .r{text-align:right;color:#777;width:25%;font-size:8pt}
  .meas-grid .ab{color:#c0392b}
  .desc p{font-size:10.5pt;margin-bottom:5px;text-align:justify}
  .desc .lbl{font-weight:700}
  .concl p{font-size:10.5pt;margin-bottom:4px}
  /* v.fit-54: bloco da assinatura — imagem completa centralizada como bloco único,
     sem texto HTML adicional. Decisão Dr. Genius após comparação visual A/B/C. */
  /* assinatura eletronica: rubrica isolada (PNG transparente) sobreposta a linha + dados em texto HTML */
  .sig-block{margin-top:34px;text-align:center;position:relative}
  .sig-block .rub{display:block;margin:0 auto -42px;height:164px;width:auto;opacity:.97;pointer-events:none;position:relative;z-index:2}
  .sig-block .sig-line{width:300px;max-width:72%;margin:0 auto;border-top:1.3px solid #111;position:relative;z-index:1}
  .sig-block .sig-name{font-weight:700;font-size:11pt;margin-top:4px;color:#111;letter-spacing:.2px}
  .sig-block .sig-qual{font-style:italic;font-size:9.5pt;line-height:1.3;color:#222}
  .foot{position:absolute;bottom:12mm;left:18mm;font-size:8.5pt;color:#555}
  /* rodape institucional do laudo (linha unica, pe da pagina A4) */
  .brandfoot{position:absolute;bottom:6mm;left:0;right:0;text-align:center;font-size:7pt;color:#9a9a9a;white-space:nowrap;letter-spacing:.2px;z-index:2}
  .empty-note{color:#bbb;font-style:italic}
  /* edição inline na descrição/conclusão (modo híbrido) */
  .ed-btn{display:inline-block;background:#eef2f7;border:1px solid #c8d0dc;color:#445;font-size:9pt;line-height:1;padding:2px 5px;border-radius:4px;cursor:pointer;margin-left:6px;vertical-align:middle}
  .ed-btn:hover{background:#d6dde8;border-color:#7a8497}
  .ed-btn.ed-reset{background:#fff4d6;border-color:#e0c060}
  .ed-btn.ed-reset:hover{background:#ffe6a0}
  .desc-edit, .concl-edit{display:block;width:100%;min-height:32px;background:#fffef5;border:1px solid #d4cf99;color:#1a1a1a;font:inherit;line-height:1.4;padding:4px 6px;border-radius:4px;resize:vertical;box-sizing:border-box;margin-top:3px;font-size:inherit}
  .concl-tools{margin-top:6px;text-align:right}
  .concl-wrap{display:block}
  .desc-edit:focus, .concl-edit:focus{outline:none;border-color:#a08c30;background:#fffaea}
  .ed-on .lbl{display:inline-block;margin-bottom:2px}
  .ed-placeholder{color:#999;font-style:italic;font-size:0.95em}
  .ed-empty{color:#888}
  @media print{
    .ed-btn{display:none!important}
    .ed-placeholder{display:none!important}
    .ed-empty{display:none!important}
    .concl-tools{display:none!important}
    .desc-edit, .concl-edit{border:none!important;background:transparent!important;padding:0!important;color:inherit!important;resize:none!important;font:inherit!important}
  }
  /* Stenosis Doppler panel */
  .sten-seg{background:var(--panel2);border-radius:8px;padding:10px 12px;margin-bottom:14px}
  .sten-row{display:flex;align-items:center;gap:12px;margin:8px 0;flex-wrap:wrap}
  .sten-lbl{font-weight:600;color:var(--accent);min-width:110px;font-size:12px}
  .sten-flds{display:flex;gap:10px;flex-wrap:wrap;align-items:center;flex:1}
  .sten-flds label{display:flex;flex-direction:column;font-size:10.5px;color:var(--dim);gap:2px}
  .sten-flds input{width:78px;background:var(--bg);border:1px solid var(--line);color:var(--ink);padding:4px 6px;border-radius:4px;font-size:12.5px;text-align:right;font-variant-numeric:tabular-nums}
  .sten-flds input:focus{outline:none;border-color:var(--accent)}
  .sten-grade{font-size:12px;font-weight:600;padding:3px 9px;border-radius:12px;margin-left:auto}
  .sten-grade.leve{background:#1f4d4a;color:#9bdfd0}
  .sten-grade.moderado,.sten-grade.moderada{background:#5a3e1a;color:#f0c068}
  .sten-grade.grave{background:var(--warn);color:#fff}
  /* painel inline dentro de um segmento (não tem fundo cinza) */
  .inline-panel{margin-top:10px;padding-top:8px;border-top:1px dashed var(--line)}
  /* Etapa 2: campo de texto livre por segmento */
  .adendo-wrap{margin-top:10px;padding-top:8px;border-top:1px dashed var(--line)}
  .adendo-lbl{display:block;font-size:8.5pt;color:#9aa;margin-bottom:4px;font-weight:600;letter-spacing:.4px;text-transform:uppercase}
  .adendo-ta{width:100%;min-height:42px;background:#0f1620;color:var(--ink);border:1px solid var(--line);border-radius:6px;padding:6px 8px;font:11pt/1.4 inherit;resize:vertical}
  .adendo-ta:focus{outline:none;border-color:#4a9eff}
  /* v.diast-46: Achados estruturados (dropdown lists) */
  .find-active{margin-top:8px;display:flex;flex-direction:column;gap:8px;flex-basis:100%}
  .finding-item{background:#0a121c;border:1px solid var(--line);border-radius:6px;padding:8px}
  .finding-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
  .finding-lbl{font-size:9.5pt;font-weight:600;color:#9fb5d6;letter-spacing:.3px}
  .finding-rm{background:#3a1a1a;color:#e89;border:1px solid #5a2a2a;border-radius:4px;padding:2px 8px;cursor:pointer;font-size:9pt}
  .finding-rm:hover{background:#5a2a2a;color:#fff}
  .finding-tl{display:block;font-size:8pt;color:#6a8;margin:4px 0 2px;font-weight:600;letter-spacing:.4px;text-transform:uppercase}
  .finding-ta{width:100%;background:#0f1620;color:var(--ink);border:1px solid var(--line);border-radius:5px;padding:5px 7px;font:10pt/1.4 inherit;resize:vertical;min-height:36px}
  .finding-ta:focus{outline:none;border-color:#4a9eff}
  /* ---- modal / toast ---- */
  .modal{position:fixed;inset:0;z-index:50;display:flex;align-items:center;justify-content:center}
  .modal-bg{position:absolute;inset:0;background:rgba(0,0,0,.55)}
  .modal-box{position:relative;background:var(--panel);border:1px solid var(--line);border-radius:10px;width:560px;max-width:92vw;max-height:80vh;display:flex;flex-direction:column;overflow:hidden}
  .modal-h{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--line);background:var(--panel2)}
  .modal-h h3{font-size:14px;color:var(--accent)}
  .modal-x{background:none;border:none;color:var(--ink-dim);font-size:22px;cursor:pointer}
  .modal-tools{display:flex;gap:8px;padding:10px 14px;border-bottom:1px solid var(--line)}
  .modal-tools input{background:var(--panel2);border:1px solid var(--line);color:var(--ink);padding:6px 9px;border-radius:5px;font-size:13px}
  .modal-tools button{background:var(--panel2);border:1px solid var(--line);color:var(--ink);padding:5px 10px;border-radius:5px;font-size:12px;cursor:pointer}
  .modal-tools button:hover{border-color:var(--accent)}
  .modal-list{flex:1;overflow-y:auto;padding:6px 0}
  .pat-row{display:flex;align-items:center;gap:10px;padding:8px 14px;border-bottom:1px solid var(--line);cursor:pointer;transition:.1s}
  .pat-row:hover{background:var(--panel2)}
  .pat-row .pat-nm{flex:1;font-weight:500}
  .pat-row .pat-dt{font-size:11.5px;color:var(--dim);font-family:ui-monospace,monospace}
  .pat-row .pat-del{background:none;border:1px solid var(--line);color:var(--warn);padding:2px 8px;border-radius:4px;font-size:11px;cursor:pointer}
  .pat-row .pat-del:hover{background:var(--warn-bg)}
  .modal-foot{padding:8px 14px;border-top:1px solid var(--line);font-size:11.5px;color:var(--dim)}
  .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:var(--panel2);border:1px solid var(--accent-d);color:var(--ink);padding:9px 18px;border-radius:8px;font-size:13px;z-index:60;opacity:0;transition:.25s;pointer-events:none;box-shadow:0 4px 16px rgba(0,0,0,.5)}
  .toast.show{opacity:1}
  .toast.err{border-color:var(--warn);color:#ffd6d4}
  /* indicador de pasta */
  #btnPasta.set{background:var(--chip-on);border-color:var(--accent);color:var(--chip-on-ink)}
  /* print: somente as folhas A4 */
  @media print{
    @page{size:A4;margin:0}
    html,body{margin:0!important;padding:0!important;background:#fff!important}
    .topbar,.editor,.modal,.toast{display:none!important}
    .main{display:block!important;grid-template-columns:none!important;overflow:visible!important;height:auto!important}
    .preview-pane{padding:0!important;margin:0!important;overflow:visible!important;background:#fff!important;display:block!important}
    .pages{display:block!important;transform:none!important;gap:0!important;margin:0!important;padding:0!important}
    /* v.fit-54: contenção HARDCORE para evitar overflow físico para 3ª página.
       - overflow:hidden corta o que excede 297mm
       - contain:paint cria um clip region (CSS Containment Spec)
       - max-height força limite duro
       - page-break-after only on first page; last page should not force another break */
    .a4{box-shadow:none!important;margin:0!important;padding:0!important;overflow:hidden!important;contain:paint!important;page-break-after:always;break-after:page;page-break-inside:avoid;break-inside:avoid;width:210mm!important;height:297mm!important;max-height:297mm!important;display:block!important;float:none!important}
    .a4:last-child{page-break-after:auto!important;break-after:auto!important}
    .a4 .content{overflow:hidden!important;max-height:297mm!important}
    /* impedir que qualquer .a4 extra (criada acidentalmente) seja visível */
    .a4:nth-of-type(n+3){display:none!important}
  }
</style>
</head>
<body data-institution="ENCOR" data-inst-name="ENCOR">
<div class="topbar">
  <span style="display:inline-block;padding:3px 10px;border-radius:12px;background:#a02020;color:white;font-size:9pt;font-weight:600;letter-spacing:0.5px;margin-right:10px">ENCOR</span>
  <h1>Ecocardiograma Transtorácico</h1>
  <span class="tag" id="vtag">v.fit-54</span>
  <span class="modo-toggle" title="Modo do exame">
    <button id="modoAdulto" class="modo-btn active">Adulto</button>
    <button id="modoPed" class="modo-btn">Pediátrico</button>
  </span>
  <span class="sp"></span>
  <button id="btnPasta" title="Escolher pasta para salvar PDFs (Ctrl+Shift+P)">Pasta…</button>
  <button id="btnBanco" title="Banco de pacientes (Ctrl+L)">Banco</button>
  <button id="btnSalvar" title="Salvar paciente (Ctrl+S)">Salvar</button>
  <button id="btnPDF" title="Gerar PDF (Ctrl+Shift+S)">PDF</button>
  <button id="btnImprimir" title="Imprimir (Ctrl+P)">Imprimir</button>
  <button id="btnCopiarConcl" title="Copiar a conclusão para a área de transferência (Ctrl+Shift+C)">📋 Copiar conclusão</button>
  <button id="zoomOut">−</button><button id="zoomIn">+</button>
  <button id="btnNovo" title="Novo laudo (Ctrl+N)">Novo</button>
</div>

<!-- Modal: Banco de pacientes -->
<div id="modalBanco" class="modal" style="display:none">
  <div class="modal-bg" onclick="closeBanco()"></div>
  <div class="modal-box">
    <div class="modal-h">
      <h3>Banco de Pacientes</h3>
      <button class="modal-x" onclick="closeBanco()">×</button>
    </div>
    <div class="modal-tools">
      <input id="bSearch" placeholder="Buscar por nome..." style="flex:1">
      <button id="bExport">Exportar JSON</button>
      <button id="bImport">Importar JSON</button>
      <input type="file" id="bImportFile" accept=".json" style="display:none">
    </div>
    <div class="modal-list" id="bList"></div>
    <div class="modal-foot"><span id="bCount"></span></div>
  </div>
</div>

<!-- Toast -->
<div id="toast" class="toast"></div>

<div class="main">
  <!-- ================= EDITOR ================= -->
  <div class="editor">
    <div class="tabs">
      <button class="active" data-tab="id">1 · Identificação</button>
      <button data-tab="med">2 · Medidas</button>
