// v.diast-46: Setas ↑/↓ navegam entre os campos numéricos da aba Medidas.
// Comportamento: dentro de <input type="number" class="mm">, ↓ vai pro próximo,
// ↑ vai pro anterior. Previne o comportamento default do browser (incrementar valor).
// Outros campos (textareas, selects, inputs de texto) NÃO são afetados.
document.addEventListener('keydown', (e)=>{
  if(e.key!=='ArrowDown' && e.key!=='ArrowUp') return;
  const el = e.target;
  if(!(el instanceof HTMLInputElement)) return;
  // só atuar em inputs .mm do editor (campos compactos de medidas).
  // Inclui type=text e type=number (a maior parte do projeto usa text).
  if(!el.classList.contains('mm')) return;
  // pega todos os inputs .mm visíveis do editor, em ordem do DOM
  const numericInputs = Array.from(document.querySelectorAll('.editor input.mm'))
    .filter(inp => inp.offsetParent !== null);
  const i = numericInputs.indexOf(el);
  if(i<0) return;
  e.preventDefault();
  const next = e.key==='ArrowDown' ? numericInputs[i+1] : numericInputs[i-1];
  if(next){ next.focus(); next.select?.(); }
});

