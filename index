/* Calcula Z-score pediátrico para uma estrutura, dada uma medida em mm e a BSA.
   Retorna {z, mean_mm, classe, label} ou null se BSA fora da validade ou input inválido. */
function zPettersen(key, valueMm, bsa){
  if(valueMm==null||isNaN(valueMm)||valueMm<=0)return null;
  if(bsa==null||isNaN(bsa)||bsa<=0)return null;
  if(bsa>=2.0)return {z:null, mean_mm:null, classe:'fora_bsa', label:PETTERSEN_Z[key]?.lbl||key, msg:'BSA ≥ 2,0 — fora do limite de validade Pettersen 2008'};
  const c=PETTERSEN_Z[key]; if(!c)return null;
  const meanY = c.b0 + c.b1*bsa + c.b2*bsa*bsa + c.b3*bsa*bsa*bsa;
  const mean_cm = Math.exp(meanY);
  const mean_mm = mean_cm*10;
  const value_cm = valueMm/10;
  const z = (Math.log(value_cm) - meanY) / Math.sqrt(c.mse);
  // Classificação simplificada (5 níveis, conforme guideline pediátrico canônico):
  // < -2 → Hipoplásico  /  -2 a +2 → Normal  /  +2 a +3 → Disc. aumentado
  //  +3 a +4 → Mod. aumentado  /  > +4 → Importante aumento
  let classe;
  if(z < -2)      classe='hipoplasico';
  else if(z<= 2)  classe='normal';
  else if(z<= 3)  classe='aum_disc';
  else if(z<= 4)  classe='aum_mod';
  else            classe='aum_imp';
  return {z, mean_mm, classe, label:c.lbl};
}
/* Retorna o intervalo de normalidade pediátrico em mm para Z=±2 (95% da população),
   calculado a partir do nomograma Pettersen 2008 para a BSA fornecida.
   Retorna {lo_mm, hi_mm, mean_mm} ou null se BSA inválida ou estrutura desconhecida. */
function pettersenRange(key, bsa){
  if(bsa==null||isNaN(bsa)||bsa<=0||bsa>=2.0)return null;
  const c=PETTERSEN_Z[key]; if(!c)return null;
  const meanY = c.b0 + c.b1*bsa + c.b2*bsa*bsa + c.b3*bsa*bsa*bsa;
  const sd = Math.sqrt(c.mse);
  const lo_mm = Math.exp(meanY - 2*sd)*10;
  const hi_mm = Math.exp(meanY + 2*sd)*10;
  const mean_mm = Math.exp(meanY)*10;
  return {lo_mm, hi_mm, mean_mm};
}
const Z_LABELS = {
  hipoplasico:'Hipoplásico', normal:'Normal',
  aum_disc:'Discretamente aumentado', aum_mod:'Moderadamente aumentado', aum_imp:'Importante aumento',
  fora_bsa:'Fora do limite de validade'
};
const Z_CLASS_CSS = {
  hipoplasico:'z-grav', normal:'z-normal',
  aum_disc:'z-lev', aum_mod:'z-mod', aum_imp:'z-grav',
  fora_bsa:''
};

function range(s){if(!s)return null;s=s.replace(',','.');if(s.includes('–')||s.includes('-')){const[a,b]=s.split(/[–-]/).map(parseFloat);return{lo:a,hi:b};}return null;}
function flag(rowId,val,lo,hi){const r=$(rowId);if(!r)return;const c=r.querySelector('.vl');if(!c)return;r.classList.remove('flag');c.querySelectorAll('.badge').forEach(b=>b.remove());if(val==null||isNaN(val))return;let bad=false,dir='';if(lo!=null&&val<lo){bad=true;dir='lo';}if(hi!=null&&val>hi){bad=true;dir='hi';}if(bad){r.classList.add('flag');const b=document.createElement('span');b.className='badge '+(dir==='hi'?'hi':'lo');b.textContent=dir==='hi'?'↑':'↓';c.appendChild(b);}}
function flagInput(id,refTxt){const inp=$(id);if(!inp)return;const row=inp.closest('tr');const rg=range(refTxt);const v=num(id);row.classList.remove('flag');if(v!=null&&rg){if((rg.lo!=null&&v<rg.lo)||(rg.hi!=null&&v>rg.hi))row.classList.add('flag');}}

let MEAS={}; // computed values shared with preview

function compute(){
  const peso=num('peso'),alt=num('altura'),sexo=$('sexo').value;
  const isPedM = ($('modelo')?$('modelo').value:'adulto')==='pediatrico';
  let sc=null;
  if(peso&&alt){
    sc = isPedM ? F.scHaycock(peso,alt) : F.sc(peso,alt);
    $('scOut').textContent=fmt(sc,2);
  } else { $('scOut').textContent='—'; }
  // atualizar label da SC (DuBois vs Haycock)
  const scLbl=document.querySelector('.sc-pill .l');
  if(scLbl) scLbl.textContent = isPedM ? 'Superf. corpórea (Haycock) · m²' : 'Superf. corpórea (DuBois) · m²';
  $('rf_imassa').textContent = sexo==='M' ? '49–115' : '43–95';

  const DDVE=num('DDVE'),DSVE=num('DSVE'),SIV=num('SIV'),PP=num('PP');
  // limites normais por sexo (tabelas ASE/EACVI 2015 — Lang et al.)
  // ⚠️ Referências atualizadas com double-check da literatura — todos os valores que VARIAM
  // por sexo estão aqui; valores estáveis entre sexos permanecem fixos no flagInput.
  const RNORM = sexo==='M'
    ? {DDVE:[42,58], DSVE:[25,40], SIV:[6,10],  PP:[6,10],
       idxDA:[24,33], idxDSC:[22,31], erp:[0.24,0.42],
       massa:[88,224], massaIdx:[49,115], imassaH:[20,48],
       vtd:[62,150], vts:[21,61], FE:[52,72], fenc:[25,43],
       AEdiam:[30,40], AoRaiz:[24,40], AoAsc:[30,37], aoidxR:[12,21]}
    : {DDVE:[38,52], DSVE:[22,35], SIV:[6,9],   PP:[6,9],
       idxDA:[22,31], idxDSC:[24,32], erp:[0.22,0.42],
       massa:[44,88], massaIdx:[43,95],  imassaH:[18,44],
       vtd:[46,106], vts:[14,42], FE:[54,74], fenc:[27,45],
       AEdiam:[27,38], AoRaiz:[22,36], AoAsc:[27,34], aoidxR:[13,22]};
  flagInput('DDVE',RNORM.DDVE[0]+'-'+RNORM.DDVE[1]);
  flagInput('DSVE',RNORM.DSVE[0]+'-'+RNORM.DSVE[1]);
  flagInput('SIV', RNORM.SIV[0]+'-'+RNORM.SIV[1]);
  flagInput('PP',  RNORM.PP[0]+'-'+RNORM.PP[1]);
  flagInput('AEdiam',RNORM.AEdiam[0]+'-'+RNORM.AEdiam[1]);
  flagInput('AoRaiz',RNORM.AoRaiz[0]+'-'+RNORM.AoRaiz[1]);
  flagInput('AoAsc', RNORM.AoAsc[0]+'-'+RNORM.AoAsc[1]);
  flagInput('VDdiam','25-41');  // VD basal: igual para M/F
  flagInput('TAPSE','17-100');
  flagInput('FAC','35-100');

  const set=(id,v,d=1)=>{const r=$(id);if(r)r.querySelector('.vl').textContent=fmt(v,d);return v;};
  const M={};

  let idxDA,idxDSC,erp,massa,imassa,imassah,vtd,vts,fe,fenc;
  if(DDVE&&alt){idxDA=DDVE/(alt/100);set('r_idxDA',idxDA);flag('r_idxDA',idxDA,RNORM.idxDA[0],RNORM.idxDA[1]);}
  if(DDVE&&sc){idxDSC=DDVE/sc;set('r_idxDSC',idxDSC);flag('r_idxDSC',idxDSC,RNORM.idxDSC[0],RNORM.idxDSC[1]);}
  if(PP&&DDVE){erp=F.erp(PP,DDVE);set('r_erp',erp,2);flag('r_erp',erp,RNORM.erp[0],RNORM.erp[1]);}
  if(DDVE&&SIV&&PP){massa=F.massa(DDVE,SIV,PP);set('r_massa',massa);flag('r_massa',massa,RNORM.massa[0],RNORM.massa[1]);
    if(sc){imassa=massa/sc;set('r_imassa',imassa);flag('r_imassa',imassa,RNORM.massaIdx[0],RNORM.massaIdx[1]);}
    imassah=massa/Math.pow(alt/100,2.7);set('r_imassah',imassah);flag('r_imassah',imassah,RNORM.imassaH[0],RNORM.imassaH[1]);}
  if(DDVE){vtd=F.teich(DDVE);set('r_vtd',vtd);flag('r_vtd',vtd,RNORM.vtd[0],RNORM.vtd[1]);}
  if(DSVE){vts=F.teich(DSVE);set('r_vts',vts);flag('r_vts',vts,RNORM.vts[0],RNORM.vts[1]);}
  if(vtd&&vts){fe=(vtd-vts)/vtd*100;set('r_fe',fe);flag('r_fe',fe,RNORM.FE[0],RNORM.FE[1]);}
  if(DDVE&&DSVE){fenc=(DDVE-DSVE)/DDVE*100;set('r_fenc',fenc);flag('r_fenc',fenc,RNORM.fenc[0],RNORM.fenc[1]);}
  // FE Simpson manual substitui a Teichholz quando preenchida
  const FEsimp=num('FEsimp');
  let feUsada = (FEsimp!=null) ? FEsimp : fe;     // valor que será usado p/ graduação e laudo
  let feMetodo = (FEsimp!=null) ? 'Simpson' : 'Teichholz';
  flagInput('FEsimp',RNORM.FE[0]+'-'+RNORM.FE[1]);
  // atualizar rótulos de referência por sexo no editor
  setRefHelper(RNORM);

  // geometria (mantida internamente para o motor de graduação; sem caixa visual)
  let g='—';
  if(imassa!=null&&erp!=null){const cut=sexo==='M'?115:95;const hiM=imassa>cut,hiE=erp>0.42;
    g = (!hiM&&!hiE)?'normal':(hiM&&!hiE)?'Hipertrofia excêntrica':(!hiM&&hiE)?'Remodelamento concêntrico':'Hipertrofia concêntrica';}

  const AEvol=num('AEvol'),AEdiam=num('AEdiam');let aeidx;
  if(AEvol&&sc){aeidx=AEvol/sc;set('r_aeidx',aeidx);flag('r_aeidx',aeidx,16,34);}
  const ADvol=num('ADvol');let adidx;
  if(ADvol&&sc){adidx=ADvol/sc;set('r_adidx',adidx);flag('r_adidx',adidx,null,30);}
  const AoRaiz=num('AoRaiz');let aoidx;
  if(AoRaiz&&sc){aoidx=AoRaiz/sc;set('r_aoidx',aoidx);flag('r_aoidx',aoidx,RNORM.aoidxR[0],RNORM.aoidxR[1]);}
  const AoAsc=num('AoAsc');let aoascidx;
  // Aorta ascendente indexada: sem norma oficial ASE específica por sexo; mantemos
  // exibição informativa sem marcar anormalidade (o juízo clínico é pelo absoluto).
  if(AoAsc&&sc){aoascidx=AoAsc/sc;set('r_aoascidx',aoascidx);}
  flagInput('AoArco','0-31');
  const E=num('ondaE'),A=num('ondaA'),es=num('Esep'),el=num('Elat');
  let ea,eesep,eelat,eemed;
  if(E&&A){ea=E/A;set('r_ea',ea,2);flag('r_ea',ea,0.8,2.0);}
  if(E&&es){eesep=E/es;set('r_eesep',eesep,2);flag('r_eesep',eesep,null,15);}
  if(E&&el){eelat=E/el;set('r_eelat',eelat,2);flag('r_eelat',eelat,null,13);}
  if(E&&es&&el){eemed=F.eemedia(E,es,el);set('r_eemed',eemed,2);flag('r_eemed',eemed,null,14);}
  // Pressão Pulmonar: lê PSAP e PAD diretamente do painel dropdown da tricúspide LEVE.
  // Bloco "Pressão Pulmonar" do editor foi removido (v.diast-46). O cálculo de HP (Hipertensão
  // pulmonar) na conclusão continua usando esses valores fornecidos manualmente.
  const psapManual = num('ref_vt_psap');
  const padManual  = num('ref_vt_pad');
  const psap = psapManual!=null ? psapManual : null;
  const pad  = padManual!=null  ? padManual  : null;

  // ---- PEDIÁTRICO: campos extras ----
  const SIVs_p=num('SIVs'), PPVEs_p=num('PPVEs');
  const VDmed=num('VDmed'), VDlong=num('VDlong');
  const MvAnn_p=num('MvAnn'), TvAnn_p=num('TvAnn');
  const AoAnn_p=num('AoAnn'), AoStj_p=num('AoStj');
  const AoArchD_p=num('AoArchD'), AoIsthmus_p=num('AoIsthmus');
  const PvAnn_p=num('PvAnn'), MPA_p=num('MPA'), RPA_p=num('RPA'), LPA_p=num('LPA');
  // FS: fração de encurtamento = (DDVE − DSVE)/DDVE × 100 — normal 28–44% (ASE/pediatric)
  let fs=null;
  if(DDVE&&DSVE&&DDVE>0){fs=(DDVE-DSVE)/DDVE*100; set('r_fs',fs,0); flag('r_fs',fs,28,44);}
  // AE/Ao ratio: relação clássica pediátrica — normal <1,5
  let aeao=null;
  if(AEdiam&&AoRaiz&&AoRaiz>0){aeao=AEdiam/AoRaiz; set('r_aeao',aeao,2); flag('r_aeao',aeao,null,1.5);}

  MEAS={sc,peso,alt,DDVE,DSVE,SIV,PP,idxDA,idxDSC,erp,massa,imassa,imassah,vtd,vts,fe,fenc,
        FEsimp,feUsada,feMetodo,
        GLS:(num('GLS')!=null ? -Math.abs(num('GLS')) : null),
        AEdiam,AEvol,aeidx,VDdiam:num('VDdiam'),TAPSE:num('TAPSE'),FAC:num('FAC'),ADvol,adidx,
        AoRaiz,aoidx,AoAsc,aoascidx,AoArco:num('AoArco'),
        E,A,es,el,ea,eesep,eelat,eemed,TD:num('TD'),psap,PAD:pad,sexo,geom:g,RNORM,
        // campos pediátricos extras
        SIVs:SIVs_p, PPVEs:PPVEs_p, fs, aeao,
        VDmed, VDlong,
        MvAnn:MvAnn_p, TvAnn:TvAnn_p,
        AoAnn:AoAnn_p, AoStj:AoStj_p, AoArchD:AoArchD_p, AoIsthmus:AoIsthmus_p,
        PvAnn:PvAnn_p, MPA:MPA_p, RPA:RPA_p, LPA:LPA_p};
  // disfunção sistólica: mostra/oculta o campo "à custa de" conforme FEVE reduzida
  window.__disfCausa = ($('disfCausa')?$('disfCausa').value:'')||'';
  const feRed = gradeFE(feUsada, RNORM.FE);
  const dbox=$('disfBox'); if(dbox) dbox.style.display = feRed ? 'block' : 'none';
  grade();
  // badges de estenose no editor
  const setStBadge=(id,sten)=>{const e=$(id);if(!e)return;e.className='sten-grade';if(sten){e.classList.add(sten.grau);e.textContent=sten.grau.charAt(0).toUpperCase()+sten.grau.slice(1);}else{e.textContent='';}};
  setStBadge('stMtOut', MEAS.stenMt);
  // GLS: eco do valor (sempre negativo) + grau na coluna de valor do editor
  const vlG=$('vlGLS');
  if(vlG){
    if(MEAS.GLS!=null && !isNaN(MEAS.GLS)){
      const gg=Math.abs(MEAS.GLS);
      let gl = gg>=18?'normal' : gg>=16?'limítrofe' : gg>=13?'reduzido' : 'grav. reduzido';
      vlG.textContent='-'+fmt(gg,1)+'% · '+gl;
    } else { vlG.textContent='—'; }
  }
  // CAM: badge de grau + alerta de gradiente sem FC (regra inegociável)
  const camEl=$('cam_out');
  if(camEl){
    const cg=$('cam_grau')?.value||'';
    camEl.className='sten-grade';
    if(cg){
      const map={disc:'Discreta',mod:'Moderada',imp:'Importante',caseosa:'Caseosa'};
      const cls={disc:'leve',mod:'moderado',imp:'grave',caseosa:'leve'}[cg];
      camEl.classList.add(cls);
      const gm=num('cam_gmed'), fcv=num('cam_fc');
      const faltaFC = (gm!=null && fcv==null) || ((cg==='mod'||cg==='imp') && (gm==null||fcv==null));
      camEl.textContent = map[cg] + (faltaFC ? ' · ⚠ informar gradiente + FC' : '');
    } else { camEl.textContent=''; }
  }
  // Valva aórtica: badge resumindo morfologia + estenose + insuficiência (dupla lesão)
  const vaEl=$('va_alt_out');
  if(vaEl){
    vaEl.className='sten-grade';
    const morfo=$('ref_va_morfo')?.value||'tri';
    const est=$('ref_va_est')?.value||'', refl=$('ref_va_refl')?.value||'';
    const we={escl:'esclerose',disc:'discreta',mod:'moderada',imp:'importante'};  // estenose
    const wr={disc:'leve',mod:'moderada',imp:'grave'};                            // insuficiência
    const parts=[];
    if(morfo==='bi') parts.push('bicúspide');
    const isEsten=(est==='disc'||est==='mod'||est==='imp');
    if(isEsten && refl) parts.push(`dupla lesão (E:${we[est]}/I:${wr[refl]})`);
    else { if(est) parts.push('estenose '+we[est]); if(refl) parts.push('insuf. '+wr[refl]); }
    if(parts.length){
      const sev = (est==='imp'||refl==='imp')?'grave':(est==='mod'||refl==='mod')?'moderado':'leve';
      vaEl.classList.add(sev);
      vaEl.textContent=parts.join(' · ');
    } else { vaEl.textContent=''; }
  }
  // badge pericárdio (lâmina de derrame)
  const pEl=$('periOut');
  if(pEl){
    pEl.className='sten-grade';
    const v=num('periEsp');
    if(v!=null){
      if(v<5){ pEl.classList.add('leve'); pEl.textContent='Fisiológico'; }
      else if(v<10){ pEl.classList.add('leve'); pEl.textContent='Leve'; }
      else if(v<20){ pEl.classList.add('moderado'); pEl.textContent='Moderado'; }
      else { pEl.classList.add('grave'); pEl.textContent='Grave'; }
    } else { pEl.textContent=''; }
  }
  // atualiza as referências do editor (à esquerda) quando em modo pediátrico
  updateEditorRefsPediatric();
  renderPreview();
}
