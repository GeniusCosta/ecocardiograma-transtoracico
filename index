          cg.addEventListener('change',camToggle); cg.addEventListener('input',camToggle);
        }
        ['cam_loc','cam_ext','cam_esp','cam_gmed','cam_fc','cam_refl'].forEach(id=>{
          const el=$(id); if(el && !el.__wired){el.__wired=true; el.addEventListener('input',compute); el.addEventListener('change',compute);}
        });
      },0);
    }

    // Painel de Pericárdio (lâmina de derrame) — agora dentro do segmento "Pericárdio"
    // (movido de "Outros dados" em v.diast-46 a pedido do Dr. Genius).
    if(seg.key==='peri'){
      const panel=document.createElement('div');panel.className='sten-row inline-panel';
      panel.innerHTML=`
        <div class="sten-lbl">Pericárdio (lâmina de derrame)</div>
        <div class="sten-flds">
          <label>Espessura<input class="mm" id="periEsp" type="number" step="0.1" placeholder="mm"></label>
