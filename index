/* ====================== PASTA DE SAÍDA (File System Access API) ====================== */
async function pickFolder(){
  // v.fit-54: bloqueio prévio do file:// removido. O Edge moderno suporta a API
  // mesmo com file://; o Chrome bloqueia mas devolve SecurityError que é capturado.
  // Deixamos o navegador decidir, em vez de bloquear preventivamente.
  if(!('showDirectoryPicker' in window)){
    toast('Navegador não suporta seleção de pasta — o PDF será baixado em Downloads', true);
    return;
  }
  try{
    dirHandle = await window.showDirectoryPicker({mode:'readwrite'});
    $('btnPasta').textContent='Pasta: '+dirHandle.name;
    $('btnPasta').classList.add('set');
    toast('Pasta configurada: '+dirHandle.name);
  }catch(e){
    if(e && e.name === 'AbortError') return;  // cancelamento legítimo — silencioso
    console.error('[Pasta] Erro ao abrir picker:', e);
    // Mensagens específicas por tipo de erro
    let msg;
    if(e && e.name === 'SecurityError'){
      msg = 'Chrome bloqueia "Escolher pasta" em arquivos abertos via file://. Abra o arquivo no Microsoft Edge para usar esse recurso, ou os PDFs irão para a pasta Downloads.';
    } else {
      msg = 'Falha ao escolher pasta: '+(e && e.message ? e.message : e)+' — PDFs irão para Downloads';
    }
    toast(msg, true);
  }
}
$('btnPasta').onclick=pickFolder;
async function savePdfToFolder(blob, baseName){
  // tenta salvar na pasta; se houver conflito, anexa data; senão faz download normal
  if(!dirHandle){
    const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=baseName+'.pdf'; a.click(); URL.revokeObjectURL(a.href);
    return baseName+'.pdf (download)';
  }
  let name=baseName+'.pdf';
  try{
    // verifica conflito
    let conflict=false;
    try{ await dirHandle.getFileHandle(name); conflict=true; }catch(_){ conflict=false; }
    if(conflict){
      const d=new Date(); const stamp=`${d.getFullYear()}${String(d.getMonth()+1).padStart(2,'0')}${String(d.getDate()).padStart(2,'0')}`;
      name = baseName+'_'+stamp+'.pdf';
      // se ainda conflitar, adiciona hora
      try{ await dirHandle.getFileHandle(name); const hh=`${String(d.getHours()).padStart(2,'0')}${String(d.getMinutes()).padStart(2,'0')}`; name=baseName+'_'+stamp+'_'+hh+'.pdf'; }catch(_){}
    }
    const fh=await dirHandle.getFileHandle(name,{create:true});
    const w=await fh.createWritable(); await w.write(blob); await w.close();
    return name;
  }catch(e){
    // fallback: download normal — mas LOGA o erro real para diagnóstico (v.bugfix-49)
    console.error('[PDF] Falha ao salvar na pasta — usando download:', e);
    toast('Erro ao salvar na pasta ('+(e&&e.message||e)+') — baixando para Downloads', true);
    const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=name; a.click(); URL.revokeObjectURL(a.href);
    return name+' (download — pasta falhou)';
  }
}

/* ====================== GERAÇÃO DE PDF (2 páginas A4) ====================== */
async function gerarPDF(){
  const nome=($('pNome').value||'').trim();
  if(!nome){ toast('Preencha o nome do paciente antes de gerar o PDF', true); return; }
  if(typeof html2canvas==='undefined' || !(window.jspdf||window.jsPDF)){ toast('Bibliotecas de PDF não carregadas (verifique conexão)', true); return; }
  const { jsPDF } = window.jspdf;
  toast('Gerando PDF...');
  // força escala 1 das páginas e prepara DOM para captura limpa
  const pages=$('pages'); const prevT=pages.style.transform; pages.style.transform='none';
  const printSnap = prepareForPrint();   // troca textareas/botões por texto
  try{
    const pdf = new jsPDF({orientation:'portrait', unit:'mm', format:'a4'});
    const pageEls=[$('a4p1'),$('a4p2')];
    for(let i=0;i<pageEls.length;i++){
      const el=pageEls[i];
      const canvas=await html2canvas(el,{scale:2,useCORS:true,backgroundColor:'#ffffff',windowWidth:el.offsetWidth,windowHeight:el.offsetHeight});
      const img=canvas.toDataURL('image/jpeg',0.92);
      if(i>0) pdf.addPage();
      pdf.addImage(img,'JPEG',0,0,210,297);
    }
    const blob=pdf.output('blob');
    const base=sanitizeName(nome);
    const saved=await savePdfToFolder(blob,base);
    toast('PDF salvo: '+saved);
  }catch(err){
    console.error(err); toast('Erro ao gerar PDF: '+err.message, true);
  }finally{
    restoreAfterPrint(printSnap);
    pages.style.transform=prevT;
  }
}
/* Substitui temporariamente textareas e botões por texto-só, para a captura PDF/print ficar idêntica ao laudo */
function prepareForPrint(){
  const snap=[];
  document.querySelectorAll('#oDesc textarea.desc-edit, #oConcl textarea.concl-edit').forEach(ta=>{
    const span=document.createElement('span'); span.textContent=ta.value;
    snap.push({orig:ta, parent:ta.parentNode, next:ta.nextSibling, replacement:span});
    ta.parentNode.replaceChild(span, ta);
  });
  document.querySelectorAll('#oDesc .ed-btn, #oConcl .ed-btn, #oDesc .ed-placeholder, #oDesc .ed-empty, .concl-tools').forEach(el=>{
    snap.push({orig:el, prevDisplay:el.style.display, mode:'hide'});
    el.style.display='none';
  });
  // se conclusão estava em modo manual, ela já virou span — converter quebras de linha em <br>
  document.querySelectorAll('#oConcl span').forEach(sp=>{
    if(sp.textContent.includes('\n')){
      sp.innerHTML = sp.textContent.split('\n').map(l=>`<p>${l}</p>`).join('');
    }
  });
  // v.fit-54: re-medir e ajustar página 2 após as substituições (botões removidos
  // mudam a altura do conteúdo, e o fit precisa ser recalculado)
  fitPage2();
  return snap;
}
function restoreAfterPrint(snap){
  // restaura na ordem inversa
  [...snap].reverse().forEach(s=>{
    if(s.mode==='hide'){ s.orig.style.display=s.prevDisplay||''; }
    else { s.replacement.parentNode.replaceChild(s.orig, s.replacement); }
  });
  // v.fit-54: recalcular fit após restaurar elementos (textareas voltam, altura muda)
  fitPage2();
}
// faz o mesmo p/ Ctrl+P (window.print)
// v.fit-54: aumentar delay para 150ms (era 30ms) para o navegador ter tempo
// de aplicar as mudanças de font-size aplicadas pelo fitPage2 ANTES de capturar
// a renderização para impressão. Sem isso, o Chrome desktop pode capturar o
// estado antigo e gerar uma 3ª página.
const _origPrint = window.print.bind(window);
window.print = function(){
  const snap=prepareForPrint();
  // Forçar reflow para garantir que os style changes foram aplicados
  void $('a4p2').offsetHeight;
  setTimeout(()=>{ try{ _origPrint(); }finally{ setTimeout(()=>restoreAfterPrint(snap),200); } }, 150);
};
$('btnPDF').onclick=gerarPDF;
$('btnSalvar').onclick=patSave;
$('btnImprimir').onclick=()=>window.print();

/* ====================== COPIAR CONCLUSÃO (v.fit-54) ======================
   Pega o texto da conclusão renderizada (#oConcl) e copia para o clipboard.
   - Preserva quebras de linha entre parágrafos
   - Remove o botão "✎ Editar conclusão" do texto copiado
   - Funciona em qualquer navegador via navigator.clipboard.writeText, com
     fallback para document.execCommand('copy') em contextos antigos. */
async function copiarConclusao(){
  const oConcl = $('oConcl');
  if(!oConcl){ toast('Não foi possível localizar a conclusão', true); return; }
  // Coletar texto de cada <p>, juntando com quebra de linha
  const paragrafos = Array.from(oConcl.querySelectorAll('p, textarea'))
    .map(el => el.tagName==='TEXTAREA' ? el.value : el.textContent.trim())
    .filter(Boolean);
  // Pode ter um botão escondido — filtrar qualquer texto vindo de botões
  const text = paragrafos.join('\n');
  if(!text){ toast('Conclusão vazia — nada para copiar', true); return; }
  try{
    if(navigator.clipboard && navigator.clipboard.writeText){
      await navigator.clipboard.writeText(text);
    } else {
      // Fallback para contextos sem Clipboard API (HTTP não seguro / navegador antigo)
      const ta=document.createElement('textarea');
      ta.value=text; ta.style.position='fixed'; ta.style.opacity='0';
      document.body.appendChild(ta); ta.select();
      document.execCommand('copy'); document.body.removeChild(ta);
    }
    toast('Conclusão copiada ('+text.length+' caracteres)');
  }catch(e){
    console.error('[CopiarConcl] Falha:', e);
    toast('Falha ao copiar: '+(e && e.message ? e.message : e), true);
  }
}
$('btnCopiarConcl').onclick = copiarConclusao;

