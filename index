    const val=MEAS[key];
    let disp='';
    let ab=false;
    if(val!=null&&!isNaN(val)){
      disp=fmt(val,dec==null?1:dec);
      if(lo!=null&&val<lo)ab=true; if(hi!=null&&val>hi)ab=true;
    }
    const valCell = disp ? `${disp}${un?(' '+un):''}` : '';
    // em pediátrico, a coluna de referência mostra o intervalo de normalidade pediátrico
    // (calculado a partir do nomograma Pettersen 2008 para a BSA da criança)
    let refTxt;
    if(isPed){
      if(key==='fe'||key==='FEsimp'){
        refTxt='≥55';
        if(val!=null && val<55) ab=true;
      } else {
        const pkey = PETTERSEN_MAP[key];
        if(pkey && MEAS.sc){
          const rng = pettersenRange(pkey, MEAS.sc);
          if(rng){
            // formato: intervalo normal em mm; se há valor medido, adiciona Z-score
            const rangeTxt = `${fmt(rng.lo_mm,1)}–${fmt(rng.hi_mm,1)} mm`;
            if(val!=null){
              const z = zPettersen(pkey, val, MEAS.sc);
              if(z && z.z!=null){
                const cls = Z_CLASS_CSS[z.classe]||'';
                refTxt = `<span style="color:#888;font-size:7.8pt">${rangeTxt}</span> <span class="z-cell ${cls}">Z ${z.z>=0?'+':''}${fmt(z.z,1)}</span>`;
                if(z.z<-2 || z.z>2) ab=true;
              } else refTxt = rangeTxt;
            } else {
              refTxt = `<span style="color:#888;font-size:8pt">${rangeTxt}</span>`;
            }
          } else if(MEAS.sc && MEAS.sc>=2.0){
            refTxt = '<span style="color:#888;font-size:7.8pt">BSA fora do limite Pettersen</span>';
          } else { refTxt='—'; }
        } else {
          // sem nomograma pediátrico → SUPRIME o valor fixo do adulto (que seria errado)
          refTxt = '—';
        }
      }
    } else {
      refTxt = ref||'';
    }
    rows+=`<tr><td class="lbl">${lbl}</td><td class="v ${ab?'ab':''}">${valCell}</td><td class="r">${refTxt}</td></tr>`;
  });
  $('oMeas').innerHTML=rows;

  // ---- descrição ----
  const auto=(MEAS.auto)||{desc:{},concl:{}};
  const autoBySeg={};
  Object.values(auto.desc).forEach(o=>{(autoBySeg[o.seg]=autoBySeg[o.seg]||[]).push(o.t);});
  // segmentos editáveis (modo híbrido: chips por padrão, livre quando o usuário edita).
  // v.diast-46: TODOS os segmentos passam a ser editáveis diretamente na página do laudo,
  // através do botão ✎ que aparece ao final do segmento. Antes alguns (dim, aorta, cve,
  // dve, cvd, out) não tinham essa opção.
  const EDITABLE_SEG = new Set(['dim','aorta','cve','strain','dve','cvd','vm','va','vt','vp','sep','peri','out']);
  let html='';
  DESC_LIB.forEach(seg=>{
    if(isPed && seg.key==='aorta')return;
    const st=descState[seg.key];
    const autos=autoBySeg[seg.key]||[];
    let lbl=seg.label;
    if(isPed){ if(seg.key==='vm')lbl='Valva atrioventricular esquerda:'; if(seg.key==='vt')lbl='Valva atrioventricular direita:'; }
    let manual=[];
    if(st&&st.size){
      const normalId=seg.items.find(i=>i.x)?.id;
      seg.items.forEach(i=>{ if(st.has(i.id)){ if(autos.length && i.id===normalId) return; manual.push(interp(i.t)); } });
    }
    // achados estruturados ativos (FINDINGS_LIB) — textos editáveis pelo usuário
    const findingsHere = FINDINGS_LIB
      .filter(f=>f.seg===seg.key && findingsState[f.id].active)
      .map(f=>(findingsState[f.id].desc||'').trim()).filter(Boolean);
    const parts=[...autos,...manual,...findingsHere];
    // adendo livre (Etapa 2): texto manual concatenado depois dos automatismos do segmento
    const adendo = (adendoState[seg.key]||'').trim();
    if(adendo){
      // Caso especial: se o segmento NÃO tem nenhum automatismo nem chip manual ativo
      // além do "Normal" default, o adendo substitui a frase padrão "Normal".
      // Caso contrário, o adendo é concatenado depois dos automatismos.
      const normalId = seg.items.find(i=>i.x)?.id;
      const onlySilentDefault = (
        autos.length===0 &&
        findingsHere.length===0 &&
        manual.length===1 &&
        st && st.size===1 &&
        normalId && st.has(normalId)
      );
      if(onlySilentDefault){
        parts.length=0;
      }
      parts.push(adendo);
    }
    // Se há achado ativo (substitui o "Normal" default mas não os automatismos)
    if(findingsHere.length>0){
      const normalId = seg.items.find(i=>i.x)?.id;
      const isOnlyNormalChip = st && st.size===1 && normalId && st.has(normalId);
      if(isOnlyNormalChip && manual.length===1){
        // remove a frase do "Normal" — não é coerente ter "Normal" + achado
        const idxNormal = parts.indexOf(manual[0]);
        if(idxNormal>=0) parts.splice(idxNormal,1);
      }
    }
    // texto automático (baseline)
    const autoText = parts.join(' ');
    // se segmento foi editado manualmente, usar override
    const isEditable = EDITABLE_SEG.has(seg.key);
    const override = (window.__descOverride||{})[seg.key];
    if(override!=null){
      // modo manual: mostra textarea editável e botão de voltar ao automático
      html+=`<p data-seg="${seg.key}" class="ed-on"><span class="lbl">${lbl}</span> <textarea class="desc-edit" data-seg="${seg.key}" rows="2">${escapeHtml(override)}</textarea> <button class="ed-btn ed-reset" data-seg="${seg.key}" title="Voltar ao automático">🔄</button></p>`;
    } else if(parts.length===0){
      // segmento vazio: mostra botão de editar se for editável (para criar do zero)
      // Exceção: 'strain' fica oculto quando não há GLS (não deve mostrar "— sem achados —").
      if(isEditable && seg.key!=='strain'){
        html+=`<p data-seg="${seg.key}" class="ed-empty"><span class="lbl">${lbl}</span> <span class="ed-placeholder">— sem achados —</span> <button class="ed-btn ed-start" data-seg="${seg.key}" title="Editar manualmente">✎</button></p>`;
      }
      return;
    } else {
      // modo automático
      const editBtn = isEditable ? `<button class="ed-btn ed-start" data-seg="${seg.key}" title="Editar manualmente">✎</button>` : '';
      html+=`<p data-seg="${seg.key}"><span class="lbl">${lbl}</span> ${autoText} ${editBtn}</p>`;
    }
  });
  $('oDesc').innerHTML=html;
  // wire edit buttons
  $('oDesc').querySelectorAll('.ed-start').forEach(b=>b.onclick=()=>{
    const k=b.dataset.seg;
    // captura o texto atual do segmento como ponto de partida da edição
    const p=$('oDesc').querySelector(`p[data-seg="${k}"]`);
    let cur=''; if(p){ const t=p.cloneNode(true); t.querySelectorAll('.lbl,.ed-btn,.ed-placeholder').forEach(e=>e.remove()); cur=(t.textContent||'').trim(); }
    if(!window.__descOverride)window.__descOverride={};
    window.__descOverride[k]=cur;
    renderPreview();
    setTimeout(()=>{const ta=$('oDesc').querySelector(`textarea[data-seg="${k}"]`); if(ta){ta.focus();ta.setSelectionRange(ta.value.length,ta.value.length);}},20);
  });
  $('oDesc').querySelectorAll('.ed-reset').forEach(b=>b.onclick=()=>{
    const k=b.dataset.seg;
    if(window.__descOverride){ delete window.__descOverride[k]; }
    renderPreview();
    toast('Segmento restaurado ao modo automático');
  });
  $('oDesc').querySelectorAll('.desc-edit').forEach(ta=>{
    ta.addEventListener('input',()=>{
      if(!window.__descOverride)window.__descOverride={};
      window.__descOverride[ta.dataset.seg]=ta.value;
    });
    // ajuste de altura automático
    ta.style.height='auto'; ta.style.height=(ta.scrollHeight+2)+'px';
  });

  // ---- conclusão (na ORDEM dos segmentos da DESCRIÇÃO) ----
  // bucket por segment-key, mais um 'free' para texto livre
  const segOrder = DESC_LIB.map(s=>s.key);   // ordem definida em DESC_LIB
  const buckets={}; segOrder.forEach(k=>buckets[k]=[]);
  const free=[];
  const seen=new Set();
  const addLine=(segKey,line)=>{
    const k=line.toLowerCase().trim(); if(!k||seen.has(k))return;
    seen.add(k); if(segKey&&buckets[segKey])buckets[segKey].push(line); else free.push(line);
  };
  // 1) Conclusões automáticas → segment via AUTOC_SEG
  Object.entries(auto.concl).forEach(([key,txt])=>{ addLine(AUTOC_SEG[key]||null, txt); });
  // 2) Chips de descrição → conclusões traduzidas
  DESC_LIB.forEach(seg=>{
    const st=descState[seg.key]; if(!st)return;
    seg.items.forEach(it=>{ if(st.has(it.id) && CHIP2CONCL[it.id]) addLine(CHIP2CONCL[it.id].s, CHIP2CONCL[it.id].t); });
  });
  // 3) Chips aditivos da aba Conclusão (CONCL_CHIPS — v.diast-46) — respeitam a hierarquia
  //    do segmento (dim → aorta → cve → dve → cvd → vm → va → vt → vp → ...).
  CONCL_CHIPS.forEach(it=>{
    if(conChipsState.has(it.id)) addLine(it.seg||null, it.t);
  });
  // 3.5) Achados estruturados ativos (FINDINGS_LIB) — usam o segmento f.seg para hierarquia
  FINDINGS_LIB.forEach(f=>{
    if(findingsState[f.id].active){
      const txt = (findingsState[f.id].concl||'').trim();
      if(txt) addLine(f.seg, txt);
    }
  });
  // 3.7) Movimento assíncrono do septo IV — SEMPRE na linha imediatamente abaixo da
  //      descrição da função ventricular. Inserido após os demais lances do bucket 'cve'
  //      (passos 1 e 3 já adicionaram a frase da função sistólica), portanto fica por último
  //      no bucket e, na conclusão final, na linha abaixo da função ventricular.
  if(descState['cve'] && descState['cve'].has('cve_assinc')){
    addLine('cve', 'Movimento assíncrono do septo interventricular.');
  }
  // 3.6) Comentários da conclusão (COMMENTS_LIB) — vão em ITÁLICO no FIM da conclusão.
  //      São coletados separadamente para garantir posição final, depois das demais linhas.
  const activeComments = COMMENTS_LIB
    .filter(c=>commentsState[c.id].active)
    .map(c=>(commentsState[c.id].t||'').trim())
    .filter(Boolean);
  // 4) Texto livre do textarea
  $('conText').value.split('\n').map(x=>x.trim()).filter(Boolean).forEach(l=>{
    if(l==='Ecocardiograma transtorácico, com Doppler e mapeamento em cores de fluxo e tecidual, normal.' && (Object.keys(auto.concl).length||Object.values(buckets).some(a=>a.length))) return;
    addLine(null,l);
  });

  // monta HTML na ordem dos segmentos
  // texto automático completo (ponto de partida da edição)
  const autoLines=[];
  segOrder.forEach(k=>{ buckets[k].forEach(l=>autoLines.push(l)); });
  free.forEach(l=>autoLines.push(l));
  // v.diast-46: se não há nenhuma linha clínica (autoLines === 0 antes dos comentários),
  // injeta a frase Normal padrão. Decisão clínica Dr. Genius: laudo sem alterações
  // automáticas nem inserção manual deve concluir como Normal por default.
  const NORMAL_DEFAULT = 'Ecocardiograma transtorácico, com Doppler e mapeamento em cores de fluxo e tecidual, normal.';
  if(autoLines.length===0){
    autoLines.push(NORMAL_DEFAULT);
  }
  // comentários vão SEMPRE depois (em itálico no HTML, plain no texto bruto)
  activeComments.forEach(c=>autoLines.push(c));
  const autoConclText = autoLines.join('\n');

  let cHtml='';
  const conOverride = window.__conclOverride;
  if(conOverride!=null){
    cHtml=`<div class="concl-wrap"><textarea class="concl-edit" id="conclManual" rows="6">${escapeHtml(conOverride)}</textarea><div class="concl-tools"><button class="ed-btn ed-reset" id="conclReset" title="Voltar ao automático">🔄 Voltar ao automático</button></div></div>`;
  } else {
    // Comentários (activeComments) renderizados em ITÁLICO; demais linhas em texto normal.
    const commentSet = new Set(activeComments);
    cHtml = autoLines.map(l=>{
      if(commentSet.has(l)) return `<p><em>${l}</em></p>`;
      return `<p>${l}</p>`;
    }).join('') + `<div class="concl-tools"><button class="ed-btn ed-start" id="conclEdit" title="Editar manualmente">✎ Editar conclusão</button></div>`;
  }
  $('oConcl').innerHTML=cHtml;
  // wire conclusion edit
  const cEdit=$('conclEdit'); if(cEdit) cEdit.onclick=()=>{
    window.__conclOverride = autoConclText;
    renderPreview();
    setTimeout(()=>{const ta=$('conclManual'); if(ta){ta.focus();ta.setSelectionRange(ta.value.length,ta.value.length);}},20);
  };
  const cReset=$('conclReset'); if(cReset) cReset.onclick=()=>{
    window.__conclOverride=null;
    renderPreview();
    toast('Conclusão restaurada ao modo automático');
  };
  const cManual=$('conclManual'); if(cManual){
    cManual.addEventListener('input',()=>{window.__conclOverride=cManual.value;});
    cManual.style.height='auto'; cManual.style.height=(cManual.scrollHeight+4)+'px';
  }

  // rodapés (data por extenso) em ambas as páginas
  const meses=['janeiro','fevereiro','março','abril','maio','junho','julho','agosto','setembro','outubro','novembro','dezembro'];
  let fd=''; if(d){const[Y,Mo,D]=d.split('-');fd=`Barreiras-Bahia, ${parseInt(D)} de ${meses[parseInt(Mo)-1]} de ${Y}.`;}
  $('oFoot1').textContent=fd; $('oFoot2').textContent=fd;

  // v.fit-54: ajustar página 2 para que a assinatura sempre caiba dentro do A4
  // (evita que uma conclusão longa empurre a assinatura para uma 3ª página)
  fitPage2();
}

/* ====================== AUTO-FIT PÁGINA 2 (v.fit-54) ======================
   Estratégia HARDCORE para garantir que a página 2 NUNCA estoure no imprimir:

   - SOMENTE reduzir font-size do bloco da CONCLUSÃO (#oConcl) em primeira instância
   - Se ainda não couber: aplicar transform:scale() na .content INTEIRA (último recurso)
   - NUNCA usar margin-top negativa
   - NUNCA permitir overflow visível

   Diferenças vs v.fit-54:
   - Limite mínimo de fonte da conclusão: 65% (era 75%) — mais agressivo
   - Quando font 65% não basta, aplica transform:scale na .content
   - Margem extra de segurança de 10px contra arredondamentos do navegador */
function fitPage2(){
  const page = $('a4p2'); if(!page) return;
  const content = page.querySelector('.content'); if(!content) return;
  const conclEl = page.querySelector('#oConcl'); if(!conclEl) return;

  // Helper: reajusta altura de qualquer textarea (modo manual)
  const autosizeTAs = ()=>{
    conclEl.querySelectorAll('textarea').forEach(ta=>{
      ta.style.height = 'auto';
      ta.style.height = (ta.scrollHeight + 4) + 'px';
    });
  };

  // 1) RESET COMPLETO — limpar todos os ajustes anteriores
  conclEl.style.fontSize = '';
  conclEl.style.lineHeight = '';
  content.style.transform = '';
  content.style.transformOrigin = '';
  content.style.width = '';
  content.style.paddingTop = '';
  conclEl.querySelectorAll('textarea').forEach(ta=>{
    ta.style.fontSize = '';
    ta.style.lineHeight = '';
  });
  autosizeTAs();

  // 2) Cabe (com margem de segurança 10px)? Sair.
  const pageH = page.clientHeight;
  const safeH = pageH - 10;
  if(content.scrollHeight <= safeH) return;

  // 3) Etapa A: reduzir font da CONCLUSÃO progressivamente até 65%
  const baseFontSize = parseFloat(getComputedStyle(conclEl).fontSize) || 14.67;
  for(let scale = 0.95; scale >= 0.65 - 0.001; scale -= 0.05){
    conclEl.style.fontSize = (baseFontSize * scale) + 'px';
    conclEl.style.lineHeight = '1.4';
    conclEl.querySelectorAll('textarea').forEach(ta=>{
      ta.style.fontSize = (baseFontSize * scale) + 'px';
      ta.style.lineHeight = '1.4';
    });
    autosizeTAs();
    if(content.scrollHeight <= safeH) return;
  }

  // Atingimos o mínimo (65%) e ainda não coube. NÃO usamos transform:scale
  // porque escalaria o cabeçalho e geraria sobreposições visuais.
  // O overflow:hidden no @media print garante que o conteúdo extra é cortado
  // visualmente em vez de paginado para uma 3ª página física.
  // Em casos absolutamente extremos (>20 linhas de conclusão densa), o final
  // da conclusão e/ou parte da assinatura podem ser cortados visualmente —
  // mas o laudo permanece em 2 páginas.
}

