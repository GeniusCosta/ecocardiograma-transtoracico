            const fid = sel.value; if(!fid) return;
            findingsState[fid].active = true;
            sel.value = '';
            renderFindingsBlock(seg.key);
            renderPreview();
          });
        }
        if(cont) renderFindingsBlock(seg.key);
      },0);
    }

    // Adendo livre: APENAS nos segmentos vm, va, vt, vp, sep, peri, out
    // (excluídos: dim, aorta, cve, dve, cvd — decisão Dr. Genius, v.diast-46).
    const ADENDO_ALLOWED = new Set(['vm','va','vt','vp','sep','peri','out']);
    if(ADENDO_ALLOWED.has(seg.key)){
      const adendoWrap = document.createElement('div');
      adendoWrap.className = 'adendo-wrap';
