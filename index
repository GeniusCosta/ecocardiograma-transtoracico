/* ---- build chips ---- */
function buildDesc(){
  const root=$('descSegs');root.innerHTML='';
  // v.diast-46: segmentos onde o chip "Normal" não deve ser renderizado visualmente
  // (a frase padrão continua sendo gerada na descrição via descState/default).
  const HIDE_NORMAL_CHIP = new Set(['dim','aorta','cve','dve','cvd','vp']);
  // v.diast-46: segmentos completamente ocultos no editor (decisão Dr. Genius).
  // Esses segmentos não têm mais chips visuais nem adendo, então ficavam como títulos
  // órfãos. A geração da descrição/conclusão continua via automatismos do motor.
  const HIDE_SEGMENT_ENTIRELY = new Set(['dim','aorta','strain','dve','cvd']);
  DESC_LIB.forEach(seg=>{
    if(HIDE_SEGMENT_ENTIRELY.has(seg.key)) return;  // não renderiza no editor
    const d=document.createElement('div');d.className='seg';
    d.innerHTML=`<div class="seg-h">${seg.title}</div>`;
    const cd=document.createElement('div');cd.className='chips';
    seg.items.forEach(it=>{
      if(it.x && HIDE_NORMAL_CHIP.has(seg.key)) return;
      const c=document.createElement('div');c.className='chip'+(descState[seg.key].has(it.id)?' on':'');
      c.dataset.id=it.id;
      c.textContent=it.l;c.onclick=()=>toggleDesc(seg,it,c);cd.appendChild(c);
    });
    d.appendChild(cd);

    // ===== Painel de Morfologia Aórtica (apenas na va) =====
    // v.valv: Painel aórtico — campo 1 (Morfologia) + campo 2 (Alterações pareadas
    // DESCRIÇÃO→CONCLUSÃO). Substitui o antigo motor auto de estenose e o dropdown de refluxo
    // aórtico (aposentados a pedido do Dr. Genius). Ordem da descrição: morfologia → estrutura → fluxo.
    if(seg.key==='va'){
      const panel=document.createElement('div');panel.className='sten-row inline-panel';
      panel.innerHTML=`
        <div class="sten-lbl">Valva aórtica</div>
        <div class="sten-flds" style="flex-wrap:wrap">
          <label>Morfologia
            <select class="mm" id="ref_va_morfo" style="text-align:left;width:140px">
              <option value="tri">Tricúspide</option>
              <option value="bi">Bicúspide</option>
            </select>
          </label>
          <label id="lbl_va_rafe" style="display:none">Rafe (posição)<input class="mm" id="ref_va_rafe" type="text" placeholder="ex.: 4–5 h"></label>
          <label>Esclerose / Estenose
            <select class="mm" id="ref_va_est" style="text-align:left;width:170px">
              <option value="">— nenhuma —</option>
              <option value="escl">Esclerocalcificação (sem lesão)</option>
              <option value="disc">Estenose discreta</option>
              <option value="mod">Estenose moderada</option>
              <option value="imp">Estenose importante</option>
            </select>
          </label>
          <label>Insuficiência
            <select class="mm" id="ref_va_refl" style="text-align:left;width:150px">
              <option value="">— nenhuma —</option>
              <option value="disc">Refluxo leve</option>
              <option value="mod">Refluxo moderado</option>
              <option value="imp">Refluxo grave</option>
            </select>
          </label>
          <span class="sten-grade" id="va_alt_out"></span>
        </div>
        <div class="sten-flds" id="va_est_flds" style="display:none;flex-wrap:wrap">
          <label>Vel. máx. (Vmax)<input class="mm" id="ref_va_vmax" type="number" step="0.1" placeholder="m/s"></label>
          <label>Grad. médio<input class="mm" id="ref_va_gmed" type="number" step="0.1" placeholder="mmHg"></label>
          <label>Área valvar (AVA)<input class="mm" id="ref_va_ava" type="number" step="0.01" placeholder="cm²"></label>
        </div>`;
      d.appendChild(panel);
      const vaHint=document.createElement('div');vaHint.className='hint';
      vaHint.innerHTML='Discreta: Vmax 2,6–2,9 · Gmed &lt;20 · AVA &gt;1,5. Moderada: Vmax 3,0–4,0 · Gmed 20–40 · AVA 1,0–1,5. Importante: Vmax &gt;4,0 · Gmed &gt;40 · AVA &lt;1,0 (ASE 2017). Em baixo fluxo/baixo gradiente, considerar AVA indexada e SVi. Estenose + insuficiência → conclusão consolida como dupla lesão.';
      d.appendChild(vaHint);
      setTimeout(()=>{
        const morfo=$('ref_va_morfo'), est=$('ref_va_est');
        if(morfo && !morfo.__wired){
          morfo.__wired=true;
          const mh=()=>{ const r=$('lbl_va_rafe'); if(r) r.style.display = morfo.value==='bi' ? 'inline-flex':'none'; compute(); };
          morfo.addEventListener('change',mh); morfo.addEventListener('input',mh);
        }
        if(est && !est.__wired){
          est.__wired=true;
          const eh=()=>{ const f=$('va_est_flds'); if(f) f.style.display = (est.value && est.value!=='escl') ? 'flex':'none'; compute(); };
          est.addEventListener('change',eh); est.addEventListener('input',eh);
        }
        ['ref_va_refl','ref_va_rafe','ref_va_vmax','ref_va_gmed','ref_va_ava'].forEach(id=>{
          const el=$(id); if(el && !el.__wired){el.__wired=true; el.addEventListener('input',compute); el.addEventListener('change',compute);}
        });
      },0);
    }

    // ===== Painéis de Refluxo Valvar (mitral, tricúspide) =====
    // v.valv: a AÓRTICA saiu daqui — agora é tratada no painel aórtico unificado acima.
    // 2 dropdowns com campos manuais para PHT, vena contracta, ORE, volume regurgitante
    if(seg.key==='vm' || seg.key==='vt'){
      const cfg = {
        vm:{nome:'mitral',  hasPSAP:false},
        vt:{nome:'tricúspide', hasPSAP:true},  // tricúspide leve adiciona PSAP+PAD
      }[seg.key];
      const panel=document.createElement('div');panel.className='sten-row inline-panel';
      const psapFields = cfg.hasPSAP ? `
        <div class="sten-flds" id="vp_leve_${seg.key}" style="display:none;flex-wrap:wrap">
          <label>PSAP (mmHg)<input class="mm" id="ref_${seg.key}_psap" type="number" step="1" placeholder="mmHg"></label>
          <label>PAD (mmHg)<input class="mm" id="ref_${seg.key}_pad" type="number" step="1" placeholder="mmHg"></label>
        </div>` : '';
      panel.innerHTML=`
        <div class="sten-lbl">Refluxo ${cfg.nome}</div>
        <div class="sten-flds">
          <label>Grau
            <select class="mm" id="ref_${seg.key}_grau" style="text-align:left;width:140px">
              <option value="">— nenhum —</option>
              <option value="leve">Leve</option>
              <option value="mod">Moderado</option>
              <option value="grave">Grave</option>
            </select>
