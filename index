/* ====================== ATALHOS ====================== */
document.addEventListener('keydown',e=>{
  const isMac=navigator.platform.toLowerCase().includes('mac');
  const mod=isMac?e.metaKey:e.ctrlKey;
  if(!mod)return;
  // Ctrl+S → salvar paciente; Ctrl+Shift+S → PDF; Ctrl+Shift+P → pasta;
  // Ctrl+P → imprimir; Ctrl+L → banco; Ctrl+N → novo; Ctrl+Shift+C → copiar conclusão
  const k=e.key.toLowerCase();
  if(k==='s' && e.shiftKey){ e.preventDefault(); gerarPDF(); }
  else if(k==='s'){ e.preventDefault(); patSave(); }
  else if(k==='p' && e.shiftKey){ e.preventDefault(); pickFolder(); }
  else if(k==='p'){ e.preventDefault(); window.print(); }
  else if(k==='l'){ e.preventDefault(); openBanco(); }
  else if(k==='n'){ e.preventDefault(); novoLaudo(); }
  else if(k==='c' && e.shiftKey){ e.preventDefault(); copiarConclusao(); }
  else if(e.key==='Escape'){ closeBanco(); }
});
window.closeBanco=closeBanco;

