$('bImport').onclick=()=>$('bImportFile').click();
$('bImportFile').onchange=e=>{
  const f=e.target.files[0]; if(!f)return;
  const r=new FileReader();
  r.onload=()=>{
    try{
      const imp=JSON.parse(r.result);
      const all=patAll();
      let n=0; Object.entries(imp).forEach(([k,v])=>{ if(v&&v.nome&&v.snapshot){all[k]=v;n++;} });
      localStorage.setItem(LS_KEY,JSON.stringify(all));
      renderBancoList();
      toast(`Importados ${n} pacientes`);
