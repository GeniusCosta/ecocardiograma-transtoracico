function toggleDesc(seg,it,el){
  const st=descState[seg.key];const normalId=seg.items.find(i=>i.x)?.id;
  if(it.x){ st.clear(); st.add(it.id); }
  else if(it.add){ st.has(it.id)?st.delete(it.id):st.add(it.id); }  // aditivo: coexiste com o chip normal/auto
  else { st.delete(normalId); st.has(it.id)?st.delete(it.id):st.add(it.id); if(st.size===0&&normalId)st.add(normalId); }
  // refresh this segment's chips (por data-id; robusto a chips ocultos pelo HIDE_NORMAL_CHIP)
  const chips=el.parentElement.children;
