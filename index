        <div class="sten-flds" id="vp_quant_${seg.key}" style="display:none;flex-wrap:wrap">
          <label>PHT (ms)<input class="mm" id="ref_${seg.key}_pht" type="number" step="1" placeholder="ms"></label>
          <label>Vena contracta (mm)<input class="mm" id="ref_${seg.key}_vc" type="number" step="0.1" placeholder="mm"></label>
          <label>ORE (cm²)<input class="mm" id="ref_${seg.key}_ore" type="number" step="0.01" placeholder="cm²"></label>
          <label>Vol. regurgitante (mL/bat)<input class="mm" id="ref_${seg.key}_vol" type="number" step="1" placeholder="mL/bat"></label>
        </div>`;
      d.appendChild(panel);
      const hint=document.createElement('div');hint.className='hint';
      hint.innerHTML = cfg.hasPSAP
        ? 'Tricúspide: todos os graus mostram apenas PSAP e PAD. Leve não entra na conclusão; moderado/grave aparecem como insuficiência tricúspide.'
        : 'Leve gera a frase clássica; moderado/grave permitem inserir parâmetros quantitativos (PHT, vena contracta, ORE, volume regurgitante).';
      d.appendChild(hint);
      // wire — após inserir no DOM
      setTimeout(()=>{
        const grau=$('ref_'+seg.key+'_grau'); if(grau && !grau.__wired){grau.__wired=true;
          // BUG FIX v.fit-54: ouvir AMBOS 'change' e 'input' garante propagação
          // em todos os navegadores (Chrome/Firefox/Safari/Edge). Ver linha 1641.
          const grauHandler = ()=>{
            const v=grau.value;
            const psapBlk=$('vp_leve_'+seg.key);
            const quantBlk=$('vp_quant_'+seg.key);
            // Tricúspide: PSAP/PAD para TODOS os graus (leve, mod, grave); NUNCA mostra PHT/VC/ORE/Vol
            // Mitral/Aórtica: sem PSAP; PHT/VC/ORE/Vol só para mod/grave
            if(cfg.hasPSAP){
              if(psapBlk) psapBlk.style.display = v ? 'flex' : 'none';
              if(quantBlk) quantBlk.style.display = 'none';
            } else {
              if(psapBlk) psapBlk.style.display = 'none';
              if(quantBlk) quantBlk.style.display = (v==='mod' || v==='grave') ? 'flex' : 'none';
            }
            compute();
          };
          grau.addEventListener('change', grauHandler);
          grau.addEventListener('input',  grauHandler);
        }
        ['pht','vc','ore','vol','psap','pad'].forEach(k=>{
          // estes são inputs numéricos, 'input' basta
          const el=$('ref_'+seg.key+'_'+k); if(el && !el.__wired){el.__wired=true; el.addEventListener('input',compute);}
        });
      },0);
    }

    // ===== Calcificação Anular Mitral (CAM) — achado modular parametrizado =====
    // Gera descrição + conclusão automáticas conforme o grau selecionado, com regras de
    // segurança embutidas (estenose degenerativa graduada SOMENTE por gradiente médio + FC;
    // PHT/planimetria/continuidade declaradas não aplicáveis; CAM importante → TC cardíaca;
    // caseosa = variante benigna). Gradiente exige FC (campo bloqueante [PREENCHER]).
    if(seg.key==='vm'){
      const panel=document.createElement('div');panel.className='sten-row inline-panel';
      panel.innerHTML=`
        <div class="sten-lbl">Calcificação anular mitral (CAM)</div>
        <div class="sten-flds">
          <label>Tipo
            <select class="mm" id="cam_grau" style="text-align:left;width:210px">
