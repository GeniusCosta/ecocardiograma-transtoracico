/* Atualiza as células .rf do editor à esquerda quando em modo pediátrico.
   - Para campos com nomograma Pettersen e BSA conhecida: mostra o intervalo em mm (Z=±2).
   - Para campos sem nomograma: mostra "—" (em vez de manter o valor fixo do adulto).
   - Em modo adulto: setRefHelper já tratou os campos sexo-dependentes; restaura os demais. */
const _ORIG_RF = {};   // cache do .rf original (texto adulto) para restaurar ao voltar de pediátrico
function _cacheOriginalRefs(){
  document.querySelectorAll('.mblock tr').forEach(tr=>{
    const inp = tr.querySelector('input[id], select[id]');
    const out = tr.classList.contains('out') ? tr.id : null;
    const rf = tr.querySelector('.rf');
    if(!rf) return;
    const id = inp?.id || out;
    if(!id || _ORIG_RF[id]!=null) return;
    _ORIG_RF[id] = rf.textContent;
  });
}
function updateEditorRefsPediatric(){
  if(Object.keys(_ORIG_RF).length===0) _cacheOriginalRefs();
  const isPed = $('modelo').value==='pediatrico';
  const editorPedMap = {
    DDVE:'LVIDd', DSVE:'LVIDs', SIV:'IVSd', PP:'LVPWd',
    SIVs:'IVSs', PPVEs:'LVPWs',
    AEdiam:'LA',
    VDdiam:'RVDd',
    AoRaiz:'AoSinus',
    AoAsc:'AoStj',
    AoArco:'AoArchT',
    MvAnn:'MvAnn', TvAnn:'TvAnn',
    AoAnn:'AoAnn', AoStj:'AoStj',
    AoArchD:'AoArchD', AoIsthmus:'AoIsthmus',
    PvAnn:'PvAnn', MPA:'MPA', RPA:'RPA', LPA:'LPA',
  };
  const editorPedOutsClear = ['r_idxDA','r_idxDSC','r_erp','r_massa','r_imassa','r_imassah','r_vtd','r_vts','r_fe','r_fenc','r_aeidx','r_adidx','r_aoidx','r_aoascidx','r_ea','r_eesep','r_eelat','r_eemed'];
  const setInputRef=(id,txt)=>{const e=$(id);if(e){const c=e.closest('tr').querySelector('.rf');if(c)c.textContent=txt;}};
  const setOutRef=(id,txt)=>{const e=$(id);if(e){const c=e.querySelector('.rf');if(c)c.textContent=txt;}};

  if(!isPed){
    // restaura referências do adulto a partir do cache para todos os campos NÃO sexo-dependentes;
    // os sexo-dependentes (DDVE, DSVE, SIV, PP, AEdiam, AoRaiz, AoAsc, FE, etc.) já foram atualizados em setRefHelper.
    const sexDependent = new Set(['DDVE','DSVE','SIV','PP','AEdiam','AoRaiz','AoAsc','FEsimp',
                                  'r_idxDA','r_idxDSC','r_erp','r_massa','r_imassa','r_imassah','r_vtd','r_vts','r_fe','r_fenc','r_aoidx']);
    Object.entries(_ORIG_RF).forEach(([id,txt])=>{
      if(sexDependent.has(id)) return;
      const e = $(id);
      if(!e) return;
      const c = e.closest ? e.closest('tr').querySelector('.rf') : e.querySelector?.('.rf');
      if(c) c.textContent = txt;
    });
    return;
  }

  // pediátrico
  const bsa = MEAS.sc;
  Object.entries(editorPedMap).forEach(([inputId, pkey])=>{
    if(bsa && bsa<2.0){
      const rng = pettersenRange(pkey, bsa);
      if(rng){
        setInputRef(inputId, `${fmt(rng.lo_mm,1)}–${fmt(rng.hi_mm,1)} mm`);
        return;
      }
    }
    setInputRef(inputId, '—');
  });
  setInputRef('FEsimp', '≥55');
  editorPedOutsClear.forEach(id=>setOutRef(id,'—'));
}

/* ====================== MOTOR DE GRADUAÇÃO (ASE/SBC) ====================== */
/* Tabelas por sexo: [normalLo, normalHi, leveHi, modHi]  (acima de modHi = grave)
   Para FE a direção é invertida (menor = pior): [normalLo, normalHi, leveLo, modLo] */
const GRAD={
  M:{ DDVE:[42,58,63,68], SIV:[6,10,13,16], massaIdx:[49,115,131,148], volIdx:[34,74,89,100], FE:[52,72,41,30] },
  F:{ DDVE:[38,52,56,61], SIV:[6,9,12,15],  massaIdx:[43,95,108,121],  volIdx:[29,61,70,80],  FE:[54,74,41,30] }
};
function gradeUp(v,t){ if(v==null)return null; if(v<=t[1])return null; if(v<=t[2])return 'leve'; if(v<=t[3])return 'moderado'; return 'grave'; }
function gradeFE(v,t){ if(v==null)return null; if(v>=t[0])return null; if(v>=t[2])return 'leve'; if(v>=t[3])return 'moderado'; return 'grave'; }

/* auto-frases alinhadas ao banco de frases oficial (YAML do Dr. Genius) */
function grade(){
  const m=MEAS, sx=m.sexo, T=GRAD[sx];
  const auto={desc:{}, concl:{}};
  const isPedM = ($('modelo')?$('modelo').value:'adulto')==='pediatrico';

  // ---- DDVE: dilatação do VE (apenas adultos — cortes pediátricos serão tratados na Fase 2 via Z-score) ----
  if(!isPedM){
    const gDDVE=gradeUp(m.DDVE,T.DDVE);
    if(gDDVE){
      const dDesc = gDDVE==='grave' ? 'Dilatação grave do ventrículo esquerdo.' : `Dilatação do ventrículo esquerdo de grau ${gDDVE}.`;
      const dConcl = gDDVE==='grave' ? 'Aumento grave do ventrículo esquerdo.' : `Aumento do ventrículo esquerdo de grau ${gDDVE}.`;
      auto.desc['dim_auto_dilve']={seg:'dim', t:dDesc};
      auto.concl['dilve']=dConcl;
    }
  }
  // ---- FE: disfunção sistólica (cortes ASE válidos em pediatria também) ----
  const gFE=gradeFE(m.feUsada,T.FE);
  if(gFE){
    // valor da FE (Simpson, replicado) e complemento livre "à custa de..."
    const feVal = (m.FEsimp!=null) ? fmt(m.FEsimp,0) : (m.fe!=null?fmt(m.fe,0):'__');
    const causa = (window.__disfCausa||'').trim();
    const causaTxt = causa ? ` à custa de ${causa}` : ' à custa de ___';
    const parenSimp = `(fração de ejeção do ventrículo esquerdo pelo Simpson biplanar = ${feVal}%)`;
    // DESCRIÇÃO — modelos completos
    let dDesc;
    if(gFE==='leve')      dDesc=`Função sistólica do ventrículo esquerdo levemente reduzida ${parenSimp}${causaTxt}.`;
    else if(gFE==='moderado') dDesc=`Função sistólica do ventrículo esquerdo moderadamente reduzida ${parenSimp}${causaTxt}.`;
    else                  dDesc=`Função sistólica do ventrículo esquerdo gravemente reduzida ${parenSimp}${causaTxt}.`;
    // CONCLUSÃO — modelos completos
    let dCon;
    if(gFE==='leve')      dCon=`Disfunção sistólica do ventrículo esquerdo de grau leve ${parenSimp}${causaTxt}.`;
    else if(gFE==='moderado') dCon=`Disfunção sistólica do ventrículo esquerdo de grau moderado ${parenSimp}${causaTxt}.`;
    else                  dCon=`Disfunção sistólica grave do ventrículo esquerdo ${parenSimp}${causaTxt}.`;
    auto.desc['cve_auto_disf']={seg:'cve', t:dDesc};
    auto.concl['disf']=dCon;
  }
  // ---- Strain longitudinal global do VE (GLS) — speckle tracking 2D ----
  // Faixas (Dr. Genius): ≥|18| normal · |16|–|17,9| limítrofe · |13|–|15,9| reduzido · <|13| gravemente reduzido.
  // VN: -18 a -22% (valores mais negativos = melhor deformação). Só dispara quando GLS é preenchido.
  if(m.GLS!=null && !isNaN(m.GLS)){
    const g = Math.abs(m.GLS);                 // módulo do GLS
    const disp = '-'+fmt(g,1)+'%';             // exibido sempre negativo, ex.: -20,0%
    let grauConcl, adjDesc;
    if(g>=18){      grauConcl='normal';                  adjDesc='preservada'; }
    else if(g>=16){ grauConcl='limítrofe (borderline)'; adjDesc='no limite inferior da normalidade'; }
    else if(g>=13){ grauConcl='reduzido';               adjDesc='reduzida'; }
    else {          grauConcl='gravemente reduzido';     adjDesc='gravemente reduzida'; }
    const dDescStrain = `Análise por speckle tracking bidimensional realizada em projeções apicais (4 câmaras, 2 câmaras e 3 câmaras), demonstrando deformação miocárdica longitudinal ${adjDesc}. O valor do strain longitudinal global foi de ${disp} (VN: -18 a -22%).`;
    auto.desc['strain_auto']={seg:'strain', t:dDescStrain};
    auto.concl['strain']=`Strain longitudinal global do ventrículo esquerdo ${grauConcl}: ${disp} (VN: -18 a -22%).`;
  }
  // ---- VD: disfunção sistólica do VD (TAPSE <17 OU FAC <35, ASE/EACVI) ----
  const tapseLow = m.TAPSE!=null && m.TAPSE<17;
  const facLow   = m.FAC!=null   && m.FAC<35;
  if(tapseLow || facLow){
    const detalhes=[];
    if(m.TAPSE!=null) detalhes.push(`TAPSE ${fmt(m.TAPSE,0)} mm`);
    if(m.FAC!=null)   detalhes.push(`FAC ${fmt(m.FAC,0)}%`);
    const paren = detalhes.length ? ` (${detalhes.join(' / ')})` : '';
    auto.desc['cvd_auto_disf']={seg:'cvd', t:`Função sistólica do ventrículo direito reduzida${paren}.`};
    auto.concl['disf_vd']=`Disfunção sistólica do ventrículo direito${paren}.`;
  }
  // ---- Os automatismos abaixo usam cortes do adulto; em pediátrico ficam suspensos até a Fase 2 (Z-scores) ----
  if(!isPedM){
    // Massa indexada + ERP: geometria ventricular
    const gMass=gradeUp(m.imassa,T.massaIdx);
    const hiERP = m.erp!=null && m.erp>0.42;
    const hiMass = gMass!=null;
    if(m.erp!=null && m.imassa!=null){
      if(hiERP && !hiMass){
        auto.desc['geo']={seg:'dim', t:'Aumento da espessura relativa da parede com índice de massa do ventrículo esquerdo normal.'};
        auto.concl['geo']='Remodelamento concêntrico do ventrículo esquerdo.';
      } else if(hiERP && hiMass){
        auto.desc['geo']={seg:'dim', t:'Aumento da espessura relativa da parede com aumento do índice de massa do ventrículo esquerdo.'};
        auto.concl['geo']= gMass==='grave' ? 'Hipertrofia concêntrica grave do ventrículo esquerdo.' : `Hipertrofia concêntrica do ventrículo esquerdo de grau ${gMass}.`;
      } else if(!hiERP && hiMass){
        auto.desc['geo']={seg:'dim', t:'Índice de massa do ventrículo esquerdo aumentado com espessura relativa da parede normal.'};
        auto.concl['geo']= gMass==='grave' ? 'Hipertrofia excêntrica grave do ventrículo esquerdo.' : `Hipertrofia excêntrica do ventrículo esquerdo de grau ${gMass}.`;
      }
    }
    // AE indexado
    const gAE = gradeUp(m.aeidx, sx==='M'?[16,34,41,48]:[16,34,41,48]);
    if(gAE){
      auto.desc['dim_auto_ae']={seg:'dim', t: gAE==='grave'
          ? 'Dilatação grave do átrio esquerdo (indexado pela superfície corporal).'
          : `Dilatação do átrio esquerdo de grau ${gAE} (indexado pela superfície corporal).`};
      auto.concl['ae']= gAE==='grave'
          ? 'Aumento grave do átrio esquerdo.'
          : `Aumento do átrio esquerdo de grau ${gAE}.`;
    }
    // AD/VD aumentados (cortes adultos)
    const adAumentado = (m.adidx!=null && m.adidx>30);
    const vdAumentado = (m.VDdiam!=null && m.VDdiam>41);
    if(adAumentado){
      auto.desc['dim_auto_ad']={seg:'dim', t:`Dilatação do átrio direito (índice de volume ${fmt(m.adidx,1)} mL/m²).`};
    }
    if(vdAumentado){
      auto.desc['dim_auto_vd']={seg:'dim', t:`Dilatação do ventrículo direito (diâmetro basal ${fmt(m.VDdiam,0)} mm).`};
    }
    if(adAumentado && vdAumentado){
      auto.concl['cam_dir']='Aumento das câmaras direitas.';
    } else if(adAumentado){
      auto.concl['ad_aum']='Aumento do átrio direito.';
    } else if(vdAumentado){
      auto.concl['vd_aum']='Aumento do ventrículo direito.';
    }
    // Função diastólica (algoritmo ASE 2016 simplificado — válido para adultos)
    const dia = gradeDiastolic(m);
    if(dia){
      if(dia.desc)  auto.desc['dve_auto']={seg:'dve', t: dia.desc};
      if(dia.concl) auto.concl['dve']= dia.concl;
    }
  }
  // ---- PSAP: hipertensão pulmonar (cortes oficiais 36-49 / 50-69 / >=70) ----
  if(m.psap!=null){
    let gHP=null;
    if(m.psap>=70)gHP='grave'; else if(m.psap>=50)gHP='moderado'; else if(m.psap>=36)gHP='leve';
    if(gHP){
      auto.concl['hp']= gHP==='grave'
        ? `Hipertensão pulmonar grave (PSAP ${fmt(m.psap,0)} mmHg).`
        : `Hipertensão pulmonar de grau ${gHP} (PSAP ${fmt(m.psap,0)} mmHg).`;
    } else {
      auto.concl['hp']='Ausência de hipertensão pulmonar.';
    }
    // (legado removido) Antes, o placeholder "Jato de insuf. tricúspide" da aba Medidas
    // injetava automaticamente uma frase no segmento da valva tricúspide, duplicando
    // o conteúdo gerado pelo dropdown da Etapa 1. A descrição da tricúspide agora vem
    // exclusivamente do painel dropdown "Refluxo tricúspide" (com PSAP/PAD na opção
    // Leve). A conclusão de HP (Hipertensão pulmonar) continua sendo gerada
    // automaticamente acima a partir do mesmo jato IT.
  }
  // (legado removido v.diast-46) Frase de TACP foi descontinuada junto com o bloco
  // "Pressão Pulmonar" do editor. Se o usuário precisar mencionar TACP, pode usar
  // o campo de texto livre no segmento "Função diastólica do VE".

  // ---- Prótese valvar — motor de classificação ASE 2024 (mitral e aórtica, independentes) ----
  ['ao','mt'].forEach(pos=>{
    const pre = pos==='ao'?'pAo_':'pMt_';
    const tipoRaw = $(pre+'tipo')?.value || '';
    if(!tipoRaw) return;
    const P = {
      pos,
      tipo: tipoRaw==='bio'?'bio':'mec',
      mecSub: tipoRaw==='mec_mono'?'mono':(tipoRaw==='mec_bi'?'bi':''),
      vpico:num(pre+'vpico'), gmed:num(pre+'gmed'), fc:num(pre+'fc'),
      eoa:num(pre+'eoa'), contorno:$(pre+'cont')?.value||'',
      refluxo:$(pre+'refl')?.value||'ausente',
      baseDisp:($(pre+'base')?.value||'nao')==='sim',
      altoFluxo:($(pre+'hf')?.value||'nao')==='sim',
      dvi:num(pre+'dvi'), at:num(pre+'at'), bsa:num(pre+'bsa'),
      protNum:($(pre+'num')?.value||'').trim(),
      vtiRatio:num(pre+'vti'), pht:num(pre+'pht'),
    };
    const R = classifyProsthesis(P);
    const segKey = pos==='ao'?'va':'vm';
    const cKey = pos==='ao'?'prot_ao':'prot_mt';
    auto.desc[segKey+'_auto_prot']={seg:segKey, t:R.desc};
    auto.concl[cKey]=R.concl;
    if(R.comentario) auto.concl[cKey+'_cmt']='Comentário: '+R.comentario;
    const badgeEl=$(pre+'out');
    if(badgeEl){ badgeEl.className='sten-grade '+R.badgeCls; badgeEl.textContent=R.badge; }
  });
  // ---- Pericárdio: lâmina de derrame (cortes <5 fisiológico / 5-9 leve / 10-19 mod / ≥20 grave) ----
  const periEsp = num('periEsp');
  if(periEsp!=null && periEsp>=5){
    let grau;
    if(periEsp>=20) grau='grave';
    else if(periEsp>=10) grau='moderado';
    else grau='leve';
    const lam = fmt(periEsp,1);
    auto.desc['peri_auto']={seg:'peri', t:`Líquido em espaço pericárdico circunferencial, medindo até ${lam} mm em sua maior espessura. Não se observam sinais ecocardiográficos de comprometimento hemodinâmico, tais como colapso sistólico do átrio direito, colapso diastólico do ventrículo direito, dilatação significativa da veia cava inferior com perda da responsividade respiratória ou variações respiratórias exacerbadas dos fluxos transvalvares.`};
    auto.concl['peri_dp']= grau==='grave'
      ? `Derrame pericárdico grave, sem repercussão hemodinâmica.`
      : `Derrame pericárdico de grau ${grau}, sem repercussão hemodinâmica.`;
  }

  // ---- Refluxos valvares: painéis dropdown (mitral, aórtica, tricúspide) ----
  // Insere a frase clínica completa na descrição (segmento da valva) e traduz
  // automaticamente para "Insuficiência valvar X" na conclusão.
  // Para tricúspide LEVE: a frase inclui PSAP e PAD informados manualmente.
  // Para MODERADO/GRAVE (todas as 3): inclui parâmetros quantitativos quando preenchidos
  // (PHT, vena contracta, ORE, volume regurgitante) — opcionais.
  // v.valv: MOTOR AÓRTICO (campo 1 Morfologia + campo 2 Alterações pareadas).
  // Substitui o antigo bloco de morfologia + o motor auto de estenose + o dropdown de
  // refluxo aórtico. Ordem da descrição: morfologia → estrutura/estenose → refluxo → fluxo.
  // Conclusões pareadas; estenose + insuficiência consolidam como DUPLA LESÃO.
  // Placeholders [PREENCHER] quando Vmax/Gmed/AVA/rafe não preenchidos (nunca autocompletar).
  {
    const morfo = $('ref_va_morfo')?.value || 'tri';
    const est   = $('ref_va_est')?.value || '';     // '' | escl | disc | mod | imp
    const refl  = $('ref_va_refl')?.value || '';    // '' | disc | mod | imp
    const bi    = morfo==='bi';
    const rafe  = ($('ref_va_rafe')?.value||'').trim();
    if(bi || est || refl){
      const vmax=num('ref_va_vmax'), gmed=num('ref_va_gmed'), ava=num('ref_va_ava');
      const vmaxTxt = vmax!=null?fmt(vmax,1):'[PREENCHER]';
      const gmedTxt = gmed!=null?fmt(gmed,1):'[PREENCHER]';
      const avaTxt  = ava!=null ?fmt(ava,2):'[PREENCHER]';
      const estGrauWord = {disc:'discreta', mod:'moderada', imp:'importante'};   // estenose (mantém termos da spec)
      const reflGrauWord= {disc:'leve', mod:'moderada', imp:'grave'};  // fem.: insuficiência (leve/moderada/grave)
      const reflDescWord= {disc:'leve', mod:'moderado', imp:'grave'};  // masc.: refluxo (leve/moderado/grave)
      const isEsten = (est==='disc'||est==='mod'||est==='imp');

      // ----- DESCRIÇÃO (composta) -----
      const open = bi ? (rafe ? `Valva aórtica bicúspide (rafe em posição ${rafe}).` : 'Valva aórtica bicúspide.') : 'Tricúspide.';
      let estBody='';
      if(est==='escl')      estBody='Cúspides espessadas e calcificadas, sem restrição de abertura.';
      else if(est==='disc') estBody=`Cúspides espessadas e calcificadas, com discreta restrição de abertura. Gradiente máximo/médio VE-Ao de ${vmaxTxt} / ${gmedTxt} mmHg.`;
      else if(est==='mod')  estBody=`Cúspides espessadas e calcificadas, com moderada restrição de abertura. Gradiente médio VE-Ao de ${gmedTxt} mmHg; área valvar estimada de ${avaTxt} cm².`;
      else if(est==='imp')  estBody=`Cúspides intensamente espessadas e calcificadas, com importante restrição de abertura. Gradiente médio VE-Ao de ${gmedTxt} mmHg; área valvar estimada de ${avaTxt} cm².`;
      else if(!bi)          estBody='Morfologia e dinâmica normais.';   // tri sem estenose
      else if(!refl)        estBody='Sem restrição significativa de abertura.'; // bicúspide isolada
      else                  estBody='';  // bicúspide + refluxo (sem estenose): morfologia já dita
      const reflBody = refl ? `Refluxo valvar aórtico ${reflDescWord[refl]} ao mapeamento de fluxo em cores.` : '';
      const flowNormal = (!isEsten && !refl) ? 'Fluxo transvalvar normal ao Doppler e mapeamento de fluxo em cores.' : '';
      const dDesc = [open, estBody, reflBody, flowNormal].filter(Boolean).join(' ');
      auto.desc['va_alt']={seg:'va', t:dDesc};

      // ----- CONCLUSÃO (pareada; dupla lesão consolida) -----
      if(bi) auto.concl['va_morfo_bi']='Valva aórtica bicúspide.';
      if(isEsten && refl){
        auto.concl['va_dupla']=`Dupla lesão valvar aórtica (estenose ${estGrauWord[est]} / insuficiência ${reflGrauWord[refl]}).`;
      } else {
        if(est==='escl')  auto.concl['va_escl']='Esclerocalcificação valvar aórtica, sem lesão valvar associada.';
        else if(isEsten)  auto.concl['va_esten']=`Estenose valvar aórtica ${estGrauWord[est]}.`;
        if(refl)          auto.concl['va_insuf']=`Insuficiência valvar aórtica ${reflGrauWord[refl]}.`;
      }
    }
  }

  const refluxoCfg = {
    vm:{nomeAdj:'mitral',  segCC:'mitral',  insufFem:'mitral',  hasPSAP:false},
    vt:{nomeAdj:'tricúspide', segCC:'tricúspide', insufFem:'tricúspide', hasPSAP:true},
  };
  Object.entries(refluxoCfg).forEach(([segKey,cfg])=>{
    const grauSel = ($('ref_'+segKey+'_grau')?.value)||'';
    if(!grauSel) return;
    const grauLbl = grauSel==='leve'?'leve' : grauSel==='mod'?'moderado' : 'grave';
    let desc, concl;

    if(cfg.hasPSAP){
      // ========== TRICÚSPIDE ==========
      // v.diast-46: para TODOS os graus (leve, moderado, grave) usa-se apenas PSAP e PAD.
      // Nunca PHT/VC/ORE/Vol. Refluxo LEVE NÃO entra na conclusão (decisão Dr. Genius);
      // moderado/grave aparecem como "Insuficiência valvar tricúspide ...".
      const psap = num('ref_'+segKey+'_psap');
      const pad  = num('ref_'+segKey+'_pad');
      // descrição: sempre menciona PSAP e PAD se preenchidos
      if(psap!=null && pad!=null){
        desc = `Refluxo ${cfg.nomeAdj} de grau ${grauLbl} ao Doppler e mapeamento de fluxo em cores, permitindo estimar a PSAP em ${fmt(psap,0)} mmHg, considerando uma PAD de ${fmt(pad,0)} mmHg.`;
      } else if(psap!=null){
        desc = `Refluxo ${cfg.nomeAdj} de grau ${grauLbl} ao Doppler e mapeamento de fluxo em cores, permitindo estimar a PSAP em ${fmt(psap,0)} mmHg.`;
      } else {
        desc = `Refluxo ${cfg.nomeAdj} de grau ${grauLbl} ao Doppler e mapeamento de fluxo em cores.`;
      }
      // conclusão: leve = sem entrada; moderado = com "de grau"; grave = sem "de grau"
      if(grauSel==='leve'){
        concl = null;  // não entra na conclusão
      } else if(grauSel==='grave'){
        concl = `Insuficiência valvar ${cfg.insufFem} grave.`;
      } else {
        concl = `Insuficiência valvar ${cfg.insufFem} de grau ${grauLbl}.`;
      }
    } else {
      // ========== MITRAL ==========
      if(grauSel==='leve'){
        desc = segKey==='vm'
          ? `Morfologia e dinâmica normais. Refluxo ${cfg.nomeAdj} de grau leve ao Doppler e mapeamento de fluxo em cores.`
          : `Refluxo ${cfg.nomeAdj} de grau leve ao Doppler e mapeamento de fluxo em cores.`;
        concl = `Insuficiência valvar ${cfg.insufFem} de grau leve.`;
      } else {
        // moderado ou grave — incluir parâmetros quantitativos disponíveis (PHT/VC/ORE/Vol)
        const pht = num('ref_'+segKey+'_pht');
        const vc  = num('ref_'+segKey+'_vc');
        const ore = num('ref_'+segKey+'_ore');
        const vol = num('ref_'+segKey+'_vol');
        const params=[];
        if(pht!=null) params.push(`PHT = ${fmt(pht,0)} ms`);
        if(vc!=null)  params.push(`vena contracta = ${fmt(vc,1)} mm`);
        if(ore!=null) params.push(`ORE = ${fmt(ore,2)} cm²`);
        if(vol!=null) params.push(`volume regurgitante = ${fmt(vol,0)} mL/batimento`);
        const paramTxt = params.length ? ` (${params.join('; ')})` : '';
        desc = `Refluxo ${cfg.nomeAdj} de grau ${grauLbl}${paramTxt}.`;
        concl = grauSel==='grave'
          ? `Insuficiência valvar ${cfg.insufFem} grave${paramTxt}.`
          : `Insuficiência valvar ${cfg.insufFem} de grau ${grauLbl}${paramTxt}.`;
      }
    }
    auto.desc[segKey+'_auto_refl'] = {seg:segKey, t:desc};
    if(concl!=null) auto.concl[segKey+'_refl_auto'] = concl;
  });

  // ---- Calcificação anular mitral (CAM) — achado modular ----
  // Regras inegociáveis: estenose degenerativa graduada SOMENTE por gradiente médio + FC;
  // PHT/planimetria/continuidade declaradas não aplicáveis; CAM importante → TC cardíaca;
  // caseosa = variante benigna; gradiente NUNCA sem FC ([PREENCHER]).
  const camGrau = $('cam_grau')?.value || '';
  if(camGrau){
    const loc = $('cam_loc')?.value || 'posterior';
    const ext = $('cam_ext')?.value || 'focal';
    const esp = num('cam_esp');
    const espTxt = esp!=null ? fmt(esp,0) : '[PREENCHER]';
    const gmed = num('cam_gmed');
    const fc   = num('cam_fc');
    const refl = $('cam_refl')?.value || 'ausente';
    // gradiente exige FC — frase de descrição (sentença) e parêntese de conclusão
    const gmedTxt = gmed!=null ? fmt(gmed,1) : '[PREENCHER]';
    const fcTxt   = fc!=null   ? fmt(fc,0)   : '[PREENCHER]';
    const gradSentence = `Gradiente diastólico transmitral médio de ${gmedTxt} mmHg (FC ${fcTxt} bpm).`;
    const gradParen    = `gradiente médio ${gmedTxt} mmHg, FC ${fcTxt} bpm`;
    const hasGrad = (gmed!=null || fc!=null);
    const reflFrase = refl==='ausente' ? '' : ` Refluxo mitral de grau ${refl}.`;
    const reflConcl = refl==='ausente' ? '' : ` Refluxo mitral ${refl} associado.`;
    let dDesc, dConcl;
    if(camGrau==='caseosa'){
      dDesc = `Imagem nodular ecodensa de centro ecolucente, com ~${espTxt} mm, junto ao ânulo mitral posterior, de aspecto compatível com calcificação anular mitral caseosa (variante benigna), sem sinais de massa, trombo ou vegetação.` + (hasGrad ? ` ${gradSentence}` : '');
      dConcl = `Calcificação anular mitral caseosa (variante benigna), sem repercussão hemodinâmica significativa. Achado de evolução habitualmente benigna, dispensando investigação adicional.`;
    } else if(camGrau==='disc'){
      dDesc = `Calcificação anular mitral discreta, de localização ${loc} e extensão ${ext}, com espessura máxima de ~${espTxt} mm, sem restrição à abertura valvar.` + (hasGrad ? ` ${gradSentence}` : '') + reflFrase;
      dConcl = `Calcificação anular mitral discreta, sem repercussão hemodinâmica.` + reflConcl;
    } else if(camGrau==='mod'){
      // moderada → estenose degenerativa: gradiente é obrigatório (força [PREENCHER] se faltar)
      dDesc = `Calcificação anular mitral moderada, de localização ${loc} e extensão ${ext}, com espessura máxima de ~${espTxt} mm, estendendo-se à base do folheto posterior e determinando discreta restrição à sua abertura. ${gradSentence}` + reflFrase;
      dConcl = `Calcificação anular mitral moderada com extensão à base do folheto posterior, determinando estenose mitral degenerativa (${gradParen}). Métodos de estimativa de área valvar (tempo de meia-pressão, planimetria e equação de continuidade) não aplicáveis pela natureza degenerativa da obstrução.` + reflConcl;
    } else { // imp
      dDesc = `Calcificação anular mitral extensa, de distribuição circunferencial, com espessura máxima de ~${espTxt} mm, estendendo-se a ambos os folhetos e determinando importante restrição à abertura valvar. ${gradSentence}` + reflFrase;
      dConcl = `Calcificação anular mitral importante, de distribuição circunferencial, com restrição de ambos os folhetos, determinando estenose mitral degenerativa hemodinamicamente significativa (${gradParen}). Métodos de estimativa de área valvar não aplicáveis pela natureza degenerativa.` + reflConcl + ` Recomenda-se correlação clínica e, caso se cogite intervenção, avaliação por tomografia computadorizada cardíaca para quantificação do escore de cálcio anular.`;
    }
    auto.desc['vm_auto_cam']={seg:'vm', t:dDesc};
    auto.concl['cam_mitral']=dConcl;
  }

  // ---- Estenose AÓRTICA: motor auto APOSENTADO (v.valv). Agora é seleção manual no
  //      painel "Valva aórtica" (campo Esclerose/Estenose). stenAo mantido null p/ compatibilidade.
  // ---- Estenose e dilatação da aorta: cortes do adulto (suspensos em pediátrico) ----
  let stenAo=null, stenMt=null;
  if(!isPedM){
  // ---- Estenose mitral (reumática) ----
  stenMt = gradeStenMt(num('stMtGrad'), num('stMtVel'), num('stMtArea'), num('stMtPHT'));
  if(stenMt){
    const params=stenMt.params.join(' / ');
    const grauM = stenMt.grau==='moderada' ? 'moderado' : stenMt.grau;
    auto.desc['vm_auto_sten']={seg:'vm', t:`Aumento do gradiente transvalvar mitral (${params}).`};
    auto.concl['vm_sten']= grauM==='grave'
      ? `Estenose mitral grave (${params}).`
      : `Estenose mitral de grau ${grauM} (${params}).`;
  }
  // ---- Aorta: graduação automática (raiz, ascendente, arco) ----
  // gradeAortic(valorMm, normalMaxMm, leveMin, leveMax, modMax, graveMax, aneurismaMin)
  // retorna {tipo:'normal|leve|moderado|grave|aneurisma', cm:string}  ou null
  function gradeAortic(v, normal, leveHi, modHi, graveHi, aneurMin){
    if(v==null) return null;
    if(v < normal) return null;
    const cm = (v/10).toLocaleString('pt-BR',{minimumFractionDigits:1,maximumFractionDigits:1});
    if(v >= aneurMin) return {tipo:'aneurisma', cm};
    if(v <= leveHi) return {tipo:'leve', cm};
    if(v <= modHi)  return {tipo:'moderado', cm};
    return {tipo:'grave', cm};
  }
  // Raiz aórtica: <40 normal | 40-44 leve | 45-49 mod | ≥50 grave | >60 aneurisma
  const aoRaizG = gradeAortic(m.AoRaiz, 40, 44, 49, 999, 61);
  if(aoRaizG){
    const cm = aoRaizG.cm;
    const t = aoRaizG.tipo;
    if(t==='aneurisma'){
      auto.desc['ao_raiz_d']={seg:'aorta', t:`Dilatação aneurismática da raiz aórtica (${cm} cm).`};
      auto.concl['ao_raiz']=`Aneurisma da raiz aórtica (${cm} cm).`;
    } else if(t==='grave'){
      auto.desc['ao_raiz_d']={seg:'aorta', t:`Dilatação grave da raiz aórtica (${cm} cm).`};
      auto.concl['ao_raiz']=`Ectasia grave da raiz aórtica (${cm} cm).`;
    } else {
      auto.desc['ao_raiz_d']={seg:'aorta', t:`Dilatação da raiz aórtica de grau ${t} (${cm} cm).`};
      auto.concl['ao_raiz']=`Ectasia da raiz aórtica de grau ${t} (${cm} cm).`;
    }
  }
  // Aorta ascendente: <40 normal | 40-44 leve | 45-49 mod | 50-54 grave | ≥55 aneurisma
  const aoAscG = gradeAortic(m.AoAsc, 40, 44, 49, 54, 55);
  if(aoAscG){
    const cm = aoAscG.cm;
    const t = aoAscG.tipo;
    if(t==='aneurisma'){
      auto.desc['ao_asc_d']={seg:'aorta', t:`Dilatação aneurismática da aorta ascendente (${cm} cm).`};
      auto.concl['ao_asc']=`Aneurisma da aorta ascendente (${cm} cm).`;
    } else if(t==='grave'){
      auto.desc['ao_asc_d']={seg:'aorta', t:`Dilatação grave da aorta ascendente (${cm} cm).`};
      auto.concl['ao_asc']=`Ectasia grave da aorta ascendente (${cm} cm).`;
    } else {
      auto.desc['ao_asc_d']={seg:'aorta', t:`Dilatação da aorta ascendente de grau ${t} (${cm} cm).`};
      auto.concl['ao_asc']=`Ectasia da aorta ascendente de grau ${t} (${cm} cm).`;
    }
  }
  // Arco aórtico: <35 normal | 35-39 leve | 40-44 mod | ≥45 grave | >52 aneurisma
  const aoArcoG = gradeAortic(m.AoArco, 35, 39, 44, 999, 53);
  if(aoArcoG){
    const cm = aoArcoG.cm;
    const t = aoArcoG.tipo;
    if(t==='aneurisma'){
      auto.desc['ao_arco_d']={seg:'aorta', t:`Dilatação aneurismática do arco aórtico (${cm} cm).`};
      auto.concl['ao_arco']=`Aneurisma do arco aórtico (${cm} cm).`;
    } else if(t==='grave'){
      auto.desc['ao_arco_d']={seg:'aorta', t:`Dilatação grave do arco aórtico (${cm} cm).`};
      auto.concl['ao_arco']=`Ectasia grave do arco aórtico (${cm} cm).`;
    } else {
      auto.desc['ao_arco_d']={seg:'aorta', t:`Dilatação do arco aórtico de grau ${t} (${cm} cm).`};
      auto.concl['ao_arco']=`Ectasia do arco aórtico de grau ${t} (${cm} cm).`;
    }
  }
  } // ← fim do bloco "if(!isPedM)" para estenoses e aorta

  // armazena para badges no editor
  MEAS.stenAo=stenAo; MEAS.stenMt=stenMt;

  MEAS.auto=auto;
}

/* Estenose aórtica (ACC/AHA): retorna o pior grau identificado.
   Só dispara se ao menos UM parâmetro estiver fora da faixa normal. */
function gradeStenAo(grad, vel, area, areaIdx){
  const grades=[]; const params=[]; let abnormal=false;
  if(grad!=null){ let g; if(grad>=40)g='grave'; else if(grad>=25)g='moderada'; else g='leve'; grades.push(g); params.push(`gradiente médio ${fmt(grad,0)} mmHg`); if(grad>=25)abnormal=true; }
  if(vel!=null){ let g; if(vel>=4)g='grave'; else if(vel>=3)g='moderada'; else g='leve'; grades.push(g); params.push(`Vmáx ${fmt(vel,1)} m/s`); if(vel>=3)abnormal=true; }
  if(area!=null){ let g; if(area<=1)g='grave'; else if(area<=1.5)g='moderada'; else g='leve'; grades.push(g); params.push(`área valvar ${fmt(area,2)} cm²`); if(area<=1.5)abnormal=true; }
  if(areaIdx!=null){ if(areaIdx<=0.6){grades.push('grave'); abnormal=true;} params.push(`índice de área ${fmt(areaIdx,2)} cm²/m²`); }
  if(!grades.length||!abnormal)return null;
  const order={leve:1,moderada:2,grave:3};
  let pior='leve'; grades.forEach(g=>{if(order[g]>order[pior])pior=g;});
  return {grau:pior, params};
}
/* Estenose mitral — mesma regra: só dispara se algum parâmetro estiver anormal. */
function gradeStenMt(grad, vel, area, pht){
  const grades=[]; const params=[]; let abnormal=false;
  if(area!=null){ let g; if(area<1)g='grave'; else if(area<=1.5)g='moderada'; else g='leve'; grades.push(g); params.push(`área valvar ${fmt(area,2)} cm²`); if(area<=1.5)abnormal=true; }
  if(grad!=null){ let g; if(grad>10)g='grave'; else if(grad>=5)g='moderada'; else g='leve'; grades.push(g); params.push(`gradiente médio ${fmt(grad,0)} mmHg`); if(grad>=5)abnormal=true; }
  if(vel!=null){ let g; if(vel>2.5)g='grave'; else if(vel>=1.5)g='moderada'; else g='leve'; grades.push(g); params.push(`velocidade E mitral ${fmt(vel,1)} m/s`); if(vel>=1.5)abnormal=true; }
  if(pht!=null){ let g; if(pht>=220)g='grave'; else if(pht>=150)g='moderada'; else g='leve'; grades.push(g); params.push(`PHT ${fmt(pht,0)} ms`); if(pht>=150)abnormal=true; }
  if(!grades.length||!abnormal)return null;
  const order={leve:1,moderada:2,grave:3};
  let pior='leve'; grades.forEach(g=>{if(order[g]>order[pior])pior=g;});
  return {grau:pior, params};
}

/* Motor de classificação de disfunção de prótese valvar — ASE 2024 (Zoghbi et al.).
   Determinístico: classifica em normal / possível / significativa / gradiente elevado
   não-estenótico (mismatch · alto fluxo · recuperação de pressão), aplicando a regra
   integrativa (estenose significativa exige ≥1 fluxo-dependente E ≥1 fluxo-independente
   na faixa significativa). Gradiente alto isolado nunca conclui estenose.
   Retorna {categoria, causa, desc, concl, comentario, confianca, lacunas, badge, badgeCls}. */
function classifyProsthesis(P){
  const isAo = P.pos==='ao';
  const N='normal', PO='possivel', S='significativa';
  const band=(v,fn)=> v==null?null:fn(v);
  const bVpico = band(P.vpico, v=> isAo ? (v<3?N:v<=4?PO:S) : (v<1.9?N:v<=2.5?PO:S));
  const bGmed  = band(P.gmed,  v=> isAo ? (v<20?N:v<=35?PO:S) : (v<=5?N:v<=10?PO:S));
  const bEoa   = band(P.eoa,   v=> isAo ? (v>1.2?N:v>=0.8?PO:S) : (v>=2.0?N:v>=1?PO:S));
  const bDvi   = isAo ? band(P.dvi, v=> v>=0.30?N:v>=0.25?PO:S) : null;
  const bAt    = isAo ? band(P.at,  v=> v<80?N:v<=100?PO:S) : null;
  const bPht   = !isAo ? band(P.pht, v=> v<130?N:v<=200?PO:S) : null;
  const bVti   = !isAo ? band(P.vtiRatio, v=> v<2.2?N:v<=2.5?PO:S) : null;
  const bCont  = P.contorno ? (P.contorno==='tri'?N:P.contorno==='int'?PO:S) : null;

  const flowDep   = [bVpico,bGmed].filter(x=>x!=null);
  const flowIndep = (isAo?[bEoa,bDvi]:[bEoa,bPht]).filter(x=>x!=null);
  const anyFlowDepAbn = flowDep.some(b=>b!==N);
  const flowDepSig    = flowDep.some(b=>b===S);
  const flowIndepSig  = flowIndep.some(b=>b===S);
  const discr = (isAo?[bDvi,bAt,bCont]:[bPht,bVti,bCont]).filter(x=>x!=null);
  const discrNormais = discr.length>0 && discr.every(b=>b===N);

  // EOA indexada / mismatch paciente-prótese (aórtica): sem >0,85 · mod 0,65–0,85 · grave <0,65
  let idxEoa=null, ppm=null;
  if(isAo && P.eoa!=null && P.bsa!=null && P.bsa>0){
    idxEoa = P.eoa/P.bsa;
    ppm = idxEoa>0.85?null : idxEoa>=0.65?'moderado':'grave';
  }

  let categoria, causa=null;
  if(flowDep.length===0) categoria='indeterminado';
  else if(!anyFlowDepAbn) categoria='normal';
  else if(flowDepSig && flowIndepSig) categoria='significativa';   // regra integrativa satisfeita
  else if(discrNormais){
    categoria='grad_elevado';
    if(P.tipo==='mec' && P.mecSub==='bi') causa='recuperacao';     // checar antes de obstrução
    else if(isAo && ppm) causa='mismatch';
    else if(P.altoFluxo) causa='altofluxo';
    else causa='indef';
  }
  else categoria='possivel';

  // formatação
  const f1=v=>v!=null?fmt(v,1):'[PREENCHER]';
  const f2=v=>v!=null?fmt(v,2):'[PREENCHER]';
  const f0=v=>v!=null?fmt(v,0):'[PREENCHER]';
  const posW = isAo?'aórtica':'mitral';
  const tipoW = P.tipo==='bio'?'biológica':(P.mecSub==='bi'?'mecânica duplo-disco':P.mecSub==='mono'?'mecânica monodisco':'mecânica');
  const tipoConcl = P.tipo==='bio'?'biológica':'mecânica';
  const numW = (isAo && P.protNum)?` nº ${P.protNum}`:'';
  const contW = {tri:'triangular',int:'intermediário',arr:'arredondado'}[P.contorno]||'';
  const picoW = P.contorno==='tri'?', pico precoce':(P.contorno==='arr'?', pico mesossistólico':'');
  const idxW = idxEoa!=null?fmt(idxEoa,2):null;
  const reflSent = P.refluxo==='ausente'
    ? ' Ausência de refluxo transvalvar ou paravalvar significativo.'
    : ` Refluxo ${P.refluxo} ao mapeamento de fluxo em cores.`;

  // DESCRIÇÃO
  let d;
  if(categoria==='indeterminado'){
    d = `Prótese ${tipoW}${numW} em posição ${posW}.` + reflSent;
  } else {
    const normIns = categoria==='normal'?', normofuncionante':'';
    const conn = normIns ? `${normIns}, ` : ' ';
    d = `Prótese ${tipoW}${numW} em posição ${posW}${conn}com velocidade de pico de ${f1(P.vpico)} m/s e gradiente médio de ${f1(P.gmed)} mmHg (FC ${P.fc!=null?f0(P.fc):'[PREENCHER]'} bpm).`;
    if(isAo){
      d += ` DVI de ${f2(P.dvi)} e EOA de ${f2(P.eoa)} cm².`;
      if(idxW) d += ` EOA indexada de ~${idxW} cm²/m² para BSA de ${f2(P.bsa)} m².`;
      if(P.at!=null||contW) d += ` Tempo de aceleração de ${f0(P.at)} ms${contW?`, com contorno de jato ${contW}${picoW}`:''}.`;
    } else {
      d += ` EOA de ${f2(P.eoa)} cm²`;
      const mp=[]; if(P.vtiRatio!=null)mp.push(`relação VTI de ${f1(P.vtiRatio)}`); if(P.pht!=null)mp.push(`PHT de ${f0(P.pht)} ms`);
      d += mp.length?`, ${mp.join(' e ')}.`:'.';
      if(contW) d += ` Contorno de jato ${contW}${picoW}.`;
    }
    d += reflSent;
  }

  // CONCLUSÃO
  let c;
  if(categoria==='normal') c=`Prótese ${tipoConcl} em posição ${posW} normofuncionante.`;
  else if(categoria==='possivel') c=`Prótese ${tipoConcl} em posição ${posW} com gradientes em faixa intermediária — achados compatíveis com possível disfunção do tipo estenose, a esclarecer.`;
  else if(categoria==='significativa') c=`Prótese ${tipoConcl} em posição ${posW} com disfunção do tipo estenose, significativa.`;
  else if(categoria==='grad_elevado'){
    const preserv = isAo?'DVI, tempo de aceleração e contorno do jato preservados':'PHT e parâmetros fluxo-independentes preservados';
    if(causa==='mismatch') c=`Prótese ${tipoConcl} em posição ${posW} com gradiente médio elevado, porém com ${preserv} — achados compatíveis com mismatch paciente-prótese${ppm?` ${ppm}`:''}${idxW?` (EOA indexada ~${idxW} cm²/m²)`:''}, sem evidência de disfunção estrutural do tipo estenose.`;
    else if(causa==='recuperacao') c=`Prótese ${tipoConcl} (duplo-disco) em posição ${posW} com gradiente médio elevado, porém com ${preserv} — gradiente atribuível a recuperação de pressão (orifício central), sem evidência de disfunção estrutural do tipo estenose.`;
    else if(causa==='altofluxo') c=`Prótese ${tipoConcl} em posição ${posW} com gradiente médio elevado, porém com ${preserv} — gradiente atribuível a estado de alto fluxo, sem evidência de disfunção estrutural do tipo estenose.`;
    else c=`Prótese ${tipoConcl} em posição ${posW} com gradiente médio elevado e ${preserv}, sem evidência de disfunção estrutural; recomenda-se afastar mismatch paciente-prótese e estado de alto fluxo.`;
  }
  else c=`Prótese ${tipoConcl} em posição ${posW} — dados insuficientes para classificação funcional (informar velocidade de pico e gradiente médio com FC).`;

  // COMENTÁRIO
  let comentario=null;
  if(categoria==='possivel') comentario='Recomenda-se comparação com estudo ecocardiográfico de base/seriado e, se indicado, complementação por ecocardiograma transesofágico para avaliação de deterioração estrutural valvar; afastar contribuição de estado de alto fluxo.';
  else if(categoria==='significativa') comentario='Recomenda-se ecocardiograma transesofágico e correlação clínica para definição de conduta.';

  // CONFIANÇA + LACUNAS
  const lac=[];
  if(P.gmed!=null && P.fc==null) lac.push('FC');
  if(P.vpico==null) lac.push('Vpico'); if(P.gmed==null) lac.push('Gmed');
  if(isAo){ if(P.dvi==null) lac.push('DVI'); if(P.eoa==null) lac.push('EOA'); if(P.at==null) lac.push('AT'); if(P.bsa==null) lac.push('BSA'); }
  else { if(P.eoa==null) lac.push('EOA'); if(P.pht==null) lac.push('PHT'); }
  if(!P.baseDisp) lac.push('estudo de base');
  let confianca;
  if(categoria==='normal'||categoria==='significativa'||(categoria==='grad_elevado'&&causa==='mismatch')) confianca='alta';
  else if(categoria==='possivel'||(categoria==='grad_elevado'&&causa!=='indef')) confianca='moderada';
  else confianca='baixa';

  // badge editor (não impresso)
  const catLabel={normal:'FUNÇÃO NORMAL',possivel:'POSSÍVEL DISFUNÇÃO (estenose) — a esclarecer',significativa:'DISFUNÇÃO TIPO ESTENOSE, SIGNIFICATIVA',grad_elevado:'GRADIENTE ELEVADO NÃO-ESTENÓTICO',indeterminado:'DADOS INSUFICIENTES'}[categoria];
  const causaLabel={mismatch:' (mismatch)',recuperacao:' (recuperação de pressão)',altofluxo:' (alto fluxo)',indef:' (afastar mismatch/alto fluxo)'}[causa]||'';
  const badge = `${catLabel}${causaLabel} · confiança ${confianca}${lac.length?' · faltam: '+lac.join(', '):''}`;
  const badgeCls = categoria==='normal'?'leve':(categoria==='significativa'?'grave':(categoria==='possivel'?'moderado':'leve'));

  return {categoria,causa,desc:d,concl:c,comentario,confianca,lacunas:lac,badge,badgeCls};
}

/* Algoritmo ASE/EACVI 2016 para função diastólica (fiel ao fluxograma).
   Retorna {desc, concl, grau, indeterminado} ou null. */
/* Algoritmo ASE/EACVI 2016 (Nagueh et al.) — disfunção diastólica.
   DOIS RAMOS DEPENDENDO DA FEVE:

   ── RAMO A — FEVE PRESERVADA (≥50%, Figura 8 do guideline) ──
   Disfunção NÃO é assumida; precisa de evidência. Avaliar 4 critérios principais:
      A. E/e' média > 14
      B. e' septal < 7  OU  e' lateral < 10
      C. Volume AE indexado > 34 mL/m²
      D. Velocidade pico do refluxo tricúspide > 2,8 m/s
   - ≤ 1/4 positivo → Normal
   - 2/4 positivo → Indeterminado
   - ≥ 3/4 positivo → Disfunção; graduar por E/A
   Exceção registrada (decisão Dr. Genius Costa, idade-agnóstica):
   E/A ≤ 0,8 + E ≤ 50 → Grau I mesmo sem critérios positivos.

   ── RAMO B — FEVE REDUZIDA (<50%, Figura 9 do guideline) ──
   Axioma clínico: a disfunção diastólica precede a sistólica; portanto, em FEVE
   reduzida a disfunção diastólica é DADA COMO PRESENTE. Algoritmo entra direto
   na graduação por E/A:
      E/A ≤ 0,8 + E ≤ 50 cm/s       → Grau I
      E/A ≥ 2,0                     → Grau III
      restante (0,8<E/A<2,0 ou E/A≤0,8 com E>50):
         critérios A/C/D positivos (≥2 de 3) → Grau II
         senão                                → Grau I
   Decisão clínica: se E/A está ausente em FEVE reduzida, manter SILÊNCIO
   (não classifica nem normal nem disfunção). */
function gradeDiastolic(m){
  const E=m.E, A=m.A, ea=m.ea, eemed=m.eemed, es=m.es, el=m.el, aeidx=m.aeidx;
  // Critério D ASE 2016 original: velocidade pico do refluxo tricúspide > 2,8 m/s.
  // Como o bloco "Pressão Pulmonar" do editor foi removido (v.diast-46) e a PSAP agora
  // é digitada manualmente no dropdown da tricúspide leve, usamos PSAP > 35 mmHg
  // como proxy clínico equivalente (com PAD = 5 mmHg, v=2,8 m/s dá PSAP ≈ 36).
  const psap=m.psap;
  const feUsada=m.feUsada;

  // ---- 4 critérios principais (ASE/EACVI 2016) ----
  const critA = (eemed!=null) ? (eemed>14) : null;
  const critB_septal = (es!=null) ? (es<7)  : null;
  const critB_lateral = (el!=null) ? (el<10) : null;
  let critB;
  if(critB_septal===true || critB_lateral===true) critB=true;
  else if(critB_septal===false && critB_lateral===false) critB=false;
  else if(critB_septal===false || critB_lateral===false) critB=false;
  else critB=null;
  const critC = (aeidx!=null) ? (aeidx>34) : null;
  const critD = (psap!=null)  ? (psap>35)  : null;

  const ord={1:'I (leve)', 2:'II (moderado)', 3:'III (grave)'};

  // ================================================================
  // RAMO B — FEVE REDUZIDA (<50%) — Figura 9 ASE 2016
  // ================================================================
  if(feUsada!=null && feUsada<50){
    // Decisão clínica: sem E/A não classifica em FEVE reduzida (silêncio).
    if(ea==null) return null;

    let grau;
    if(ea<=0.8 && E!=null && E<=50){
      grau=1;
    } else if(ea>=2){
      grau=3;
    } else {
      // Faixa intermediária (E/A≤0,8 com E>50, ou 0,8<E/A<2,0):
      // Em FE REDUZIDA, basta 1 critério auxiliar positivo (E/e' médio, AE idx, jato IT)
      // para classificar como Grau II — o axioma já garante presença de disfunção,
      // os critérios auxiliares apenas diferenciam Grau I (sem elevação de pressão)
      // de Grau II (pressão de enchimento elevada).
      const aux=[critA, critC, critD].filter(c=>c!==null);
      const auxPos=aux.filter(c=>c===true).length;
      if(auxPos >= 1)                 grau=2;  // qualquer critério auxiliar positivo → pseudonormal
      else if(aux.length===0)         grau=2;  // sem dados auxiliares: presume pseudonormal (mais comum em FEr)
      else                            grau=1;  // todos os auxiliares disponíveis são negativos → relaxamento alterado
    }
    let desc = buildDiastDescSentence(ea, eemed, es, el, true);
    const concl=`Disfunção diastólica do ventrículo esquerdo grau ${ord[grau]}.`;
    return { desc, concl, grau, indeterminado:false, ramo:'FEr' };
  }

  // ================================================================
  // RAMO A — FEVE PRESERVADA (≥50% ou ausente) — Figura 8 ASE 2016
  // ================================================================
  const crits=[critA, critB, critC, critD];
  const avail = crits.filter(c=>c!==null);
  const pos = avail.filter(c=>c===true).length;
  const total = avail.length;

  // ---- EXCEÇÃO: padrão clássico de relaxamento alterado isolado ----
  // E/A ≤ 0,8 + E ≤ 50 cm/s → padrão de relaxamento alterado.
  // Decisão clínica (Dr. Genius Costa): a exceção dispara independentemente da idade.
  // O padrão Doppler por si só é considerado suficiente para caracterizar disfunção
  // diastólica grau I (leve), mesmo quando os 4 critérios principais ASE 2016 são
  // todos normais ou ausentes.
  const padraoRelaxAlterado = (ea!=null && ea<=0.8 && E!=null && E<=50);

  // Sem nenhum dado Doppler diastólico → não classifica (silencia)
  if(total === 0 && !padraoRelaxAlterado) return null;

  // v.bugfix-49: NOVA LÓGICA DE DECISÃO — DENOMINADOR FIXO = 4
  // Decisão clínica (Dr. Genius Costa): critérios não preenchidos são presumidos
  // como NEGATIVOS (priorizar especificidade, reduzir falsos positivos quando há
  // poucas medidas). Em vez de "X positivos de Y disponíveis", usamos sempre
  // "X positivos de 4 critérios totais".
  //
  // Regras (ASE 2016 adaptadas):
  //  - 0 ou 1 positivos de 4   → NORMAL
  //  - 2 positivos de 4         → INDETERMINADO (50%) → na conclusão vira Grau I (regra v.find-39)
  //  - 3 ou 4 positivos de 4    → DISFUNÇÃO (gradua por E/A)
  //
  // Diferença vs. lógica anterior: caso "1 positivo de 2 disponíveis" (50%) agora
  // vira "1 positivo de 4 totais" (25%) → NORMAL (antes era indeterminado→Grau I).
  let presenca;  // 'normal' | 'indet' | 'disf'
  if(pos <= 1)        presenca = 'normal';
  else if(pos === 2)  presenca = 'indet';
  else                presenca = 'disf';   // 3 ou 4

  // EXCEÇÃO sobrepõe-se: padrão Doppler clássico força Grau I
  if(padraoRelaxAlterado && presenca === 'normal'){
    presenca = 'disf';
  }

  // v.bugfix-49: Quando o algoritmo classifica como NORMAL mas há dados Doppler
  // disponíveis (E/A e/ou E/E' médio), retornar uma descrição neutra (sem conclusão)
  // citando os valores — para documentar que a função diastólica foi avaliada.
  // Decisão clínica Dr. Genius: "sempre que houver dados, citar E/A e E/E' médio."
  if(presenca === 'normal'){
    const hasDopplerData = (ea!=null) || (eemed!=null);
    if(!hasDopplerData) return null;  // sem dados → silêncio (cai no "Dentro da normalidade")
    return {
      desc: buildDiastDescSentence(ea, eemed, es, el, false),
      concl: null,        // não entra na conclusão
      grau: null,
      indeterminado: false,
      ramo: 'normal'
    };
  }

  // Para indeterminada (apenas no RAMO A, FEVE preservada):
  // DESCRIÇÃO menciona indeterminado; CONCLUSÃO por default classifica como Grau I.
  // Decisão clínica (Dr. Genius Costa): "quando a função diastólica for indeterminada,
  // colocar na conclusão Disfunção diastólica Grau I por default".
  if(presenca === 'indet'){
    // v.diast-46: descrição usa a frase canônica simplificada (mesma do disf).
    // Conclusão mantém "Disfunção diastólica grau I (leve)" por default (decisão Dr. Genius).
    const desc = buildDiastDescSentence(ea, eemed, es, el, false);
    return {
      desc,
      concl: 'Disfunção diastólica do ventrículo esquerdo grau I (leve).',
      grau:  1,
      indeterminado: true
    };
  }

  // presenca === 'disf' → graduar pelo perfil mitral E/A
  // Requer ao menos E/A para graduar
  if(ea==null){
    return {
      desc:  'Disfunção diastólica do ventrículo esquerdo (grau não classificado por ausência do fluxo mitral E/A).',
      concl: 'Disfunção diastólica do ventrículo esquerdo.',
      grau:  null,
      indeterminado: false
    };
  }
  let grau;
  if(ea<=0.8 && E!=null && E<=50)       grau=1;   // relaxamento alterado
  else if(ea>=2)                         grau=3;   // restritivo
  else                                   grau=2;   // pseudo-normal
  // v.diast-46: descrição simplificada, com "diminuição das ondas E'" só se houver
  // de fato diminuição (E' septal <7 OU E' lateral <10). Decisão clínica Dr. Genius.
  let desc = buildDiastDescSentence(ea, eemed, es, el, false);
  const concl = `Disfunção diastólica do ventrículo esquerdo grau ${ord[grau]}.`;
  return { desc, concl, grau, indeterminado:false };
}

/* v.diast-46: helper de construção da frase de descrição da função diastólica.
   Regras (decisão clínica Dr. Genius):
   - Se E/A presente e (E/E' médio presente): gera frase começando "Fluxo diastólico mitral..."
   - Inclui "e diminuição das ondas E' septal e E' lateral" APENAS se houver diminuição
     real (E' septal <7 OU E' lateral <10) — só uma das duas tem que estar diminuída.
   - Se em FE reduzida, adiciona "(avaliação em FE reduzida)" no final.
   - Se faltam dados para a frase completa, fallback simples mantém comportamento. */
function buildDiastDescSentence(ea, eemed, es, el, isFEr){
  const fEr = isFEr ? ' (avaliação em FE reduzida)' : '';
  if(ea==null || eemed==null){
    // fallback: frase mínima com o que estiver disponível
    if(ea!=null){
      return `Fluxo diastólico mitral com relação E/A = ${fmt(ea,2)}${fEr}.`;
    }
    return `Função diastólica do ventrículo esquerdo avaliada${fEr}.`;
  }
  // ambos E/A e E/E' médio presentes → frase canônica
  const hasDiminuicao = (es!=null && es<7) || (el!=null && el<10);
  const clauseE = hasDiminuicao ? ' e diminuição das ondas E’ septal e E’ lateral' : '';
  return `Fluxo diastólico mitral com relação E/A = ${fmt(ea,2)}${clauseE}, com relação E/E’ média de ${fmt(eemed,1)}${fEr}.`;
}

