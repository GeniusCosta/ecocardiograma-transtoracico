      const hint=document.createElement('div');hint.className='hint';
      hint.innerHTML='Cortes: &lt;5 mm fisiológico (sem disparo) · 5–9 leve · 10–19 moderado · ≥20 grave.';
      d.appendChild(hint);
      setTimeout(()=>{const el=$('periEsp'); if(el && !el.__wired){el.__wired=true; el.addEventListener('input',compute);}},0);
    }

    // ===== Campo de texto livre por segmento (Etapa 2 do refator) =====
    // Permite acrescentar texto manual ao final do segmento. O texto é apenas adendo —
    // é concatenado depois das frases geradas pelos automatismos (motores de graduação)
    // ===== Achados estruturados (dropdown list) por segmento (Etapa 3) =====
    // Renderiza, para os segmentos sep/out/vm, um dropdown de achados que, ao ser
    // selecionado, ativa um par de textareas editáveis (descrição + conclusão).
    const findingsForSeg = FINDINGS_LIB.filter(f=>f.seg===seg.key);
    if(findingsForSeg.length){
      const wrap = document.createElement('div');
