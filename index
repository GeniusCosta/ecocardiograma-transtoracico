  const R=MEAS.RNORM||{DDVE:[38,52],DSVE:[22,35],SIV:[6,9],PP:[6,9],idxDA:[22,31],idxDSC:[24,32],erp:[0.22,0.42],massa:[44,88],massaIdx:[43,95],imassaH:[18,44],vtd:[46,106],vts:[14,42],FE:[54,74],fenc:[27,45],AEdiam:[27,38],AoRaiz:[22,36],AoAsc:[27,34]};
  // resolução dinâmica de TODOS os tokens (#XXX) → varia por sexo
