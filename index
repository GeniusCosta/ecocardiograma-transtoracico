function patRestore(s){
  Object.entries(s.inputs||{}).forEach(([id,v])=>{const el=$(id);if(el)el.value=v;});
  if(s.descState){Object.keys(s.descState).forEach(k=>{descState[k]=new Set(s.descState[k]);});}
  if(s.conState){conState=new Set(s.conState);}
  if(s.conText!=null)$('conText').value=s.conText;
  window.__descOverride = s.descOverride ? {...s.descOverride} : undefined;
  window.__conclOverride = s.conclOverride!=null ? s.conclOverride : null;
  // Etapa 2: restaura adendos
  Object.keys(adendoState).forEach(k=>adendoState[k]='');
  if(s.adendos) Object.entries(s.adendos).forEach(([k,v])=>{ if(k in adendoState) adendoState[k]=v||''; });
  // v.diast-46: restaura achados e comentários
  FINDINGS_LIB.forEach(f=>{ findingsState[f.id].active=false; findingsState[f.id].desc=f.desc; findingsState[f.id].concl=f.concl; });
  COMMENTS_LIB.forEach(c=>{ commentsState[c.id].active=false; commentsState[c.id].t=c.t; });
  if(s.findings) Object.entries(s.findings).forEach(([k,v])=>{ if(k in findingsState) findingsState[k]={...findingsState[k], ...v}; });
  if(s.comments) Object.entries(s.comments).forEach(([k,v])=>{ if(k in commentsState) commentsState[k]={...commentsState[k], ...v}; });
  // v.diast-46: restaura chips da conclusão
  conChipsState.clear();
  if(Array.isArray(s.conChips)) s.conChips.forEach(id=>conChipsState.add(id));
  buildDesc();buildCon();
  // Reaplica valores nos inputs dinâmicos (painéis recriados por buildDesc) e sincroniza a
  // visibilidade dos blocos condicionais (CAM e refluxos). Antes, valores de painel se perdiam.
  Object.entries(s.inputs||{}).forEach(([id,v])=>{const el=$(id);if(el)el.value=v;});
  ['cam_grau','ref_vm_grau','ref_vt_grau','ref_va_morfo','ref_va_est','pAo_tipo','pMt_tipo'].forEach(id=>{const el=$(id);if(el)el.dispatchEvent(new Event('change'));});
  compute();
}
function patAll(){ try{ return JSON.parse(localStorage.getItem(LS_KEY)||'{}'); }catch(e){ return {}; } }
function patSave(){
  const nome=($('pNome').value||'').trim();
  if(!nome){ toast('Preencha o nome do paciente antes de salvar', true); return; }
  const all=patAll();
  const key=sanitizeName(nome);
  all[key]={nome, snapshot:patSnap()};
  localStorage.setItem(LS_KEY, JSON.stringify(all));
  toast('Paciente salvo: '+nome);
}
function patDelete(key){
  const all=patAll(); delete all[key];
  localStorage.setItem(LS_KEY, JSON.stringify(all));
  renderBancoList();
}
function patLoad(key){
  const all=patAll(); const p=all[key]; if(!p)return;
  patRestore(p.snapshot);
  closeBanco();
  toast('Paciente carregado: '+p.nome);
}
function renderBancoList(){
  const q=($('bSearch').value||'').toLowerCase();
  const all=patAll();
  const arr=Object.entries(all).map(([k,v])=>({k,nome:v.nome,dt:v.snapshot?.savedAt||''}))
                .filter(x=>!q||x.nome.toLowerCase().includes(q))
                .sort((a,b)=>(b.dt||'').localeCompare(a.dt||''));
  const list=$('bList'); list.innerHTML='';
  arr.forEach(x=>{
    const d=document.createElement('div'); d.className='pat-row';
    const dt=x.dt?new Date(x.dt).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}):'';
    d.innerHTML=`<span class="pat-nm"></span><span class="pat-dt">${dt}</span><button class="pat-del">excluir</button>`;
    d.querySelector('.pat-nm').textContent=x.nome;
    d.querySelector('.pat-nm').onclick=()=>patLoad(x.k);
    d.querySelector('.pat-dt').onclick=()=>patLoad(x.k);
    d.querySelector('.pat-del').onclick=ev=>{ev.stopPropagation();if(confirm(`Excluir ${x.nome}?`))patDelete(x.k);};
    list.appendChild(d);
  });
  $('bCount').textContent = arr.length + (arr.length===1?' paciente':' pacientes');
  if(arr.length===0)list.innerHTML='<div style="padding:30px;text-align:center;color:var(--dim);font-style:italic">Nenhum paciente encontrado.</div>';
}
function openBanco(){ $('modalBanco').style.display='flex'; $('bSearch').value=''; renderBancoList(); $('bSearch').focus(); }
function closeBanco(){ $('modalBanco').style.display='none'; }
$('btnBanco').onclick=openBanco;
