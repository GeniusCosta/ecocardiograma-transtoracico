    if(lo==null&&hi==null) return '';
    if(d!=null) return `${fmt(lo,d).replace('.',',')}–${fmt(hi,d).replace('.',',')}`;
    return `${lo}–${hi}`;
  };
  const dynRef={
    '#DDVE':fmtRange(R.DDVE[0],R.DDVE[1]),
    '#DSVE':fmtRange(R.DSVE[0],R.DSVE[1]),
    '#SIV':fmtRange(R.SIV[0],R.SIV[1]),
    '#PP':fmtRange(R.PP[0],R.PP[1]),
    '#FE':fmtRange(R.FE[0],R.FE[1]),
    '#IM':fmtRange(R.massaIdx[0],R.massaIdx[1]),
    '#MASSA':fmtRange(R.massa[0],R.massa[1]),
    '#IMASSAH':fmtRange(R.imassaH[0],R.imassaH[1]),
    '#VTD':fmtRange(R.vtd[0],R.vtd[1]),
    '#VTS':fmtRange(R.vts[0],R.vts[1]),
    '#IDXDA':fmtRange(R.idxDA[0],R.idxDA[1]),
    '#IDXDSC':fmtRange(R.idxDSC[0],R.idxDSC[1]),
    '#ERP':fmtRange(R.erp[0],R.erp[1],2),
    '#AEDIAM':fmtRange(R.AEdiam[0],R.AEdiam[1]),
    '#AORAIZ':fmtRange(R.AoRaiz[0],R.AoRaiz[1]),
    '#AOIDX':fmtRange(R.aoidxR[0],R.aoidxR[1],1),
    '#AOASC':fmtRange(R.AoAsc[0],R.AoAsc[1]),
  };
  const isPed=$('modelo').value==='pediatrico';

  // grade de medidas — TODAS as linhas sempre
  let rows='';
  if(isPed){
    const bsaTxt = MEAS.sc!=null ? fmt(MEAS.sc,2)+' m² (Haycock)' : '—';
    rows += `<tr><td class="g-h" colspan="3" style="background:#3d2466;color:#e0d0ff">EXAME PEDIÁTRICO · BSA: ${bsaTxt}</td></tr>`;
  }
  const ROWS = isPed ? PED_MROWS : MROWS;
  ROWS.forEach(r=>{
    if(r[0]==='g'){
      rows+=`<tr><td class="g-h" colspan="3">${r[1]}</td></tr>`;return;
    }
    let [lbl,key,un,ref,rg,dec]=r;
    if(ref&&ref[0]==='#')ref=dynRef[ref]||'';
    // limites lo/hi para destacar anormalidade — usa RNORM dinamicamente para todos os campos sex-dependentes
    let lo=null,hi=null;
